---
/**
 * JSON-LD Structured Data for SEO
 *
 * Types:
 *   organization — Sitewide LocalBusiness with @id anchor. Emit on every page.
 *   event        — Per-week Event with performer, free offers, EDT timezone.
 *                  Pass { date, theme, description, music } in data prop.
 *   vendor       — Organization tied to parent market via memberOf @id.
 *                  Pass vendor frontmatter in data prop.
 *   recipe       — Recipe schema for individual recipe pages.
 *   business     — LocalBusiness for village business directory entries.
 *   breadcrumb   — BreadcrumbList. Pass { items: [{ name, url }] }.
 */

interface Props {
  type: 'organization' | 'event' | 'vendor' | 'recipe' | 'business' | 'landmark' | 'breadcrumb';
  data?: Record<string, any>;
}

const { type, data = {} } = Astro.props;

const siteUrl = (Astro.site ? Astro.site.toString() : 'https://harmonicsystems.github.io').replace(/\/$/, '');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const marketUrl = `${siteUrl}${base}/`;
const orgId = `${siteUrl}${base}/#organization`;

// ── Sitewide Organization (every page) ──────────────────────────────
function getOrganizationSchema() {
  return {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    '@id': orgId,
    name: "Kinderhook Farmers Market",
    alternateName: "Kinderhook Farmer's Market",
    url: marketUrl,
    logo: `${siteUrl}${base}/logo.png`,
    image: `${siteUrl}${base}/og-image.png`,
    description: "Saturday farmers market on the Village Green in Kinderhook, New York. Local produce, prepared foods, artisan goods, and live music every Saturday from May through October.",
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Broad Street & Albany Avenue',
      addressLocality: 'Kinderhook',
      addressRegion: 'NY',
      postalCode: '12106',
      addressCountry: 'US',
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: 42.3951,
      longitude: -73.6981,
    },
    areaServed: [
      { '@type': 'City', name: 'Kinderhook' },
      { '@type': 'City', name: 'Valatie' },
      { '@type': 'City', name: 'Hudson' },
      { '@type': 'AdministrativeArea', name: 'Columbia County' },
      { '@type': 'AdministrativeArea', name: 'Hudson Valley' },
      { '@type': 'AdministrativeArea', name: 'Capital Region' },
    ],
    openingHoursSpecification: [{
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Saturday',
      opens: '08:30',
      closes: '12:30',
      validFrom: '2026-05-09',
      validThrough: '2026-10-10',
    }],
    sameAs: [
      'https://www.instagram.com/kinderhookfarmersmarket',
      'https://www.facebook.com/KinderhookFarmersMarket',
    ],
    isAccessibleForFree: true,
    publicAccess: true,
  };
}

// ── Per-week Event ──────────────────────────────────────────────────
// data: { date, theme?, description?, music?: { name } }
function getEventSchema() {
  const theme = data.theme || 'Weekly Market';
  const eventName = `Kinderhook Farmers Market — ${theme}`;
  const desc = data.description
    || `${theme} at the Kinderhook Farmers Market on the Village Green. Fresh local produce, artisan goods, and community on the Hudson Valley's favorite Saturday morning destination.`;

  // EDT (UTC-4) for May–October market season
  const startISO = `${data.date}T08:30:00-04:00`;
  const endISO = `${data.date}T12:30:00-04:00`;

  const schema: Record<string, any> = {
    '@context': 'https://schema.org',
    '@type': 'Event',
    name: eventName,
    description: desc,
    startDate: startISO,
    endDate: endISO,
    eventStatus: 'https://schema.org/EventScheduled',
    eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
    location: {
      '@type': 'Place',
      name: 'Kinderhook Village Green',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Broad Street & Albany Avenue',
        addressLocality: 'Kinderhook',
        addressRegion: 'NY',
        postalCode: '12106',
        addressCountry: 'US',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: 42.3951,
        longitude: -73.6981,
      },
    },
    image: [`${siteUrl}${base}/og-image.png`],
    organizer: {
      '@type': 'Organization',
      name: "Kinderhook Farmers Market",
      url: marketUrl,
    },
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
      availability: 'https://schema.org/InStock',
      url: marketUrl,
      validFrom: '2026-01-01T00:00:00-05:00',
    },
    isAccessibleForFree: true,
    keywords: `farmers market, Kinderhook, Hudson Valley, Columbia County, local food, ${theme}`,
  };

  // Only include performer if there's a music act
  if (data.music?.name) {
    schema.performer = [{ '@type': 'MusicGroup', name: data.music.name }];
  }

  return schema;
}

// ── Vendor (detail page) ────────────────────────────────────────────
// data: vendor frontmatter (name, description, website, instagram, facebook, categories, slug)
function getVendorSchema() {
  // Resolve Instagram handles to full URLs for sameAs
  const instagramUrl = data.instagram
    ? (data.instagram.startsWith('http') ? data.instagram : `https://instagram.com/${data.instagram.replace('@', '')}`)
    : null;
  const sameAs = [instagramUrl, data.facebook, data.website].filter(Boolean);
  return {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: data.name,
    description: data.description,
    url: data.website || `${siteUrl}${base}/vendors/${data.slug}`,
    ...(sameAs.length > 0 ? { sameAs } : {}),
    memberOf: { '@id': orgId },
    makesOffer: {
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Product',
        category: (data.categories || []).join(', '),
      },
      availableAtOrFrom: { '@id': orgId },
    },
  };
}

// ── Recipe ───────────────────────────────────────────────────────────
function getRecipeSchema() {
  return {
    '@context': 'https://schema.org',
    '@type': 'Recipe',
    name: data.title,
    description: data.description || `A community recipe from the Kinderhook Farmers Market featuring fresh Hudson Valley produce`,
    author: data.contributor ? { '@type': 'Person', name: data.contributor } : undefined,
    prepTime: data.prepTime ? `PT${data.prepTime.replace(/\s*minutes?/i, 'M').replace(/\s*hours?/i, 'H')}` : undefined,
    cookTime: data.cookTime ? `PT${data.cookTime.replace(/\s*minutes?/i, 'M').replace(/\s*hours?/i, 'H')}` : undefined,
    recipeYield: data.servings ? `${data.servings} servings` : undefined,
    recipeCategory: data.tags?.[0],
    keywords: [
      ...(data.tags || []),
      ...(data.produce || []),
      'Kinderhook', 'Hudson Valley', 'farmers market recipe',
    ].join(', '),
  };
}

// ── Village Business ────────────────────────────────────────────────
function getBusinessSchema() {
  return {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    name: data.name,
    description: data.description,
    address: {
      '@type': 'PostalAddress',
      streetAddress: data.address,
      addressLocality: 'Kinderhook',
      addressRegion: 'NY',
      postalCode: '12106',
      addressCountry: 'US',
    },
    telephone: data.phone,
    url: data.website,
    openingHours: data.hours,
    containedInPlace: {
      '@type': 'City',
      name: 'Kinderhook',
      containedInPlace: {
        '@type': 'AdministrativeArea',
        name: 'Columbia County',
      },
    },
  };
}

// ── Landmark / Tourist Attraction ───────────────────────────────────
function getLandmarkSchema() {
  const schema: Record<string, any> = {
    '@context': 'https://schema.org',
    '@type': 'TouristAttraction',
    name: data.name,
    description: data.description,
    url: data.website || `${siteUrl}${base}/discover/${data.slug}`,
    isAccessibleForFree: data.admission === 'Free' || undefined,
    publicAccess: true,
    containedInPlace: {
      '@type': 'City',
      name: 'Kinderhook',
      containedInPlace: [
        { '@type': 'AdministrativeArea', name: 'Columbia County' },
        { '@type': 'AdministrativeArea', name: 'Hudson Valley' },
      ],
    },
  };
  if (data.address) {
    schema.address = {
      '@type': 'PostalAddress',
      streetAddress: data.address,
      addressLocality: 'Kinderhook',
      addressRegion: 'NY',
      postalCode: '12106',
      addressCountry: 'US',
    };
  }
  if (data.coordinates) {
    schema.geo = {
      '@type': 'GeoCoordinates',
      latitude: data.coordinates.lat,
      longitude: data.coordinates.lng,
    };
  }
  if (data.phone) schema.telephone = data.phone;
  if (data.hours) schema.openingHours = data.hours;
  return schema;
}

// ── Breadcrumb ──────────────────────────────────────────────────────
function getBreadcrumbSchema() {
  const items = (data.items || []).map((item: { name: string; url: string }, i: number) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.name,
    item: item.url ? `${siteUrl}${base}${item.url}` : undefined,
  }));

  return {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: items,
  };
}

const schemas: Record<string, () => any> = {
  organization: getOrganizationSchema,
  event: getEventSchema,
  vendor: getVendorSchema,
  recipe: getRecipeSchema,
  business: getBusinessSchema,
  landmark: getLandmarkSchema,
  breadcrumb: getBreadcrumbSchema,
};

const schema = schemas[type]?.();
---

{schema && (
  <script type="application/ld+json" set:html={JSON.stringify(schema, null, 0)} />
)}
