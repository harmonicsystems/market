---
interface Props {
  date: string;
  displayDate: string;
  theme?: string;
  music?: { name: string; time: string };
  /**
   * Visual tone — 'dark' renders aubergine icons + black text (for light
   * backgrounds like the cream hero). 'light' renders white icons + white
   * text (for dark backgrounds like the aubergine footer).
   */
  tone?: 'dark' | 'light';
}

const { date, displayDate, theme, music, tone = 'dark' } = Astro.props;
const base = import.meta.env.BASE_URL;
const iconColor = tone === 'light' ? '#f4f2d9' : '#2E1F2F';
const textColor = tone === 'light' ? 'text-cream' : 'text-black';

// Canonical share URL + message
const shareUrl = 'https://harmonicsystems.github.io/market/';
const shareText = `Kinderhook Farmers Market — ${displayDate}, 8:30 AM–12:30 PM on the Village Green.${theme ? ' ' + theme + '.' : ''} See you there!`;

const facebookShareUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`;
const nextdoorShareUrl = `https://nextdoor.com/sharekit/?source=external&body=${encodeURIComponent(shareText)}&url=${encodeURIComponent(shareUrl)}`;

// Break displayDate into day + date for bigger typography
// "Saturday, May 9, 2026" → day="Saturday" date="May 9, 2026"
const commaIdx = displayDate.indexOf(',');
const dayName = commaIdx > 0 ? displayDate.slice(0, commaIdx) : '';
const dateRest = commaIdx > 0 ? displayDate.slice(commaIdx + 1).trim() : displayDate;
---

<div class="shareable-card-container flex flex-wrap items-center justify-center gap-4">
  <canvas id="market-card-canvas" width="1080" height="1080" class="hidden"></canvas>

  <p class={`font-display font-bold ${textColor} text-lg md:text-xl uppercase tracking-widest`}>Share the Market:</p>

  <div class="flex flex-wrap justify-center items-center gap-4">
    <a href={facebookShareUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center hover:opacity-80 transition-opacity" aria-label="Share on Facebook">
      <span class="social-icon-mask block w-10 h-10 md:w-12 md:h-12" style={`background-color: ${iconColor}; -webkit-mask-image: url('${base}/icons/FM-FACEBOOK-ICON.png'); mask-image: url('${base}/icons/FM-FACEBOOK-ICON.png');`}></span>
    </a>

    <a href={nextdoorShareUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center hover:opacity-80 transition-opacity" aria-label="Share on Nextdoor">
      <span class="social-icon-mask block w-10 h-10 md:w-12 md:h-12" style={`background-color: ${iconColor}; -webkit-mask-image: url('${base}/icons/FM-NEXTDOOR-ICON.png'); mask-image: url('${base}/icons/FM-NEXTDOOR-ICON.png');`}></span>
    </a>

    <button type="button" id="share-instagram-btn" class="inline-flex items-center justify-center hover:opacity-80 transition-opacity" aria-label="Download image to share on Instagram">
      <span class="social-icon-mask block w-10 h-10 md:w-12 md:h-12" style={`background-color: ${iconColor}; -webkit-mask-image: url('${base}/icons/FM-INSTAGRAM-ICON.png'); mask-image: url('${base}/icons/FM-INSTAGRAM-ICON.png');`}></span>
    </button>

    <button id="download-card-btn" type="button" class="inline-flex items-center justify-center hover:opacity-80 transition-opacity" aria-label="Save share image">
      <span class="social-icon-mask block w-10 h-10 md:w-12 md:h-12" style={`background-color: ${iconColor}; -webkit-mask-image: url('${base}/icons/FM-DOWNLOAD-ICON.png'); mask-image: url('${base}/icons/FM-DOWNLOAD-ICON.png');`}></span>
    </button>
  </div>
</div>

<script define:vars={{ date, displayDate, theme, music, base }}>
  const canvas = document.getElementById('market-card-canvas');
  const ctx = canvas.getContext('2d');
  const downloadBtn = document.getElementById('download-card-btn');

  // ── Asset loading ────────────────────────────────────────────────────────
  // We rebuild the homepage hero on a 1080×1080 canvas. The three image assets
  // we need — the sunflower banner, the "FARMERS" lockup SVG, and the
  // hand-drawn divider — are loaded up front and tinted at draw time with
  // source-in so they render as flat aubergine silhouettes.
  const baseUrl = (base || '/').replace(/\/$/, '');
  function loadImage(src) {
    const img = new Image();
    const ready = new Promise((resolve) => {
      img.onload = () => resolve(true);
      img.onerror = () => resolve(false);
    });
    img.src = src;
    return { img, ready };
  }
  const banner = loadImage(`${baseUrl}/icons/FM-SUNFLOWER-TOP_BANNER-STATIC.png`);
  const farmers = loadImage(`${baseUrl}/farmers-clean.svg`);
  const divider = loadImage(`${baseUrl}/icons/FM-DIVIDER_2.png`);

  // Tint an image onto the main canvas by rendering it to a scratch canvas,
  // then flood-filling with `source-in` so the fill color only shows where
  // the source's alpha was set.
  function drawTinted(img, x, y, w, h, color) {
    if (!img.complete || !img.naturalWidth) return;
    const tmp = document.createElement('canvas');
    tmp.width = w;
    tmp.height = h;
    const tctx = tmp.getContext('2d');
    tctx.drawImage(img, 0, 0, w, h);
    tctx.globalCompositeOperation = 'source-in';
    tctx.fillStyle = color;
    tctx.fillRect(0, 0, w, h);
    ctx.drawImage(tmp, x, y);
  }

  function wrapText(text, x, y, maxWidth, lineHeight) {
    const words = text.split(' ');
    let line = '';
    let yy = y;
    for (const word of words) {
      const test = line ? line + ' ' + word : word;
      if (ctx.measureText(test).width > maxWidth && line) {
        ctx.fillText(line, x, yy);
        yy += lineHeight;
        line = word;
      } else {
        line = test;
      }
    }
    if (line) ctx.fillText(line, x, yy);
    return yy; // last line's y
  }

  // Ensure the webfonts the hero uses are actually loaded before we stamp
  // text onto the canvas. Without this the browser may fall back to Georgia
  // the first time the button is clicked, then render PP Gatwick on later
  // clicks — we want the first export to match what's on screen.
  async function ensureFonts() {
    if (!document.fonts || !document.fonts.load) return;
    try {
      await Promise.all([
        document.fonts.load('700 64px "PP Gatwick"'),
        document.fonts.load('700 56px "PP Gatwick"'),
        document.fonts.load('400 32px "DM Serif Display"'),
        document.fonts.load('400 44px "DM Serif Display"'),
        document.fonts.load('400 26px "Lora"'),
      ]);
    } catch {}
  }

  async function generateCard() {
    await Promise.all([banner.ready, farmers.ready, divider.ready, ensureFonts()]);
    for (const img of [banner.img, farmers.img, divider.img]) {
      if (img.decode) { try { await img.decode(); } catch {} }
    }

    // Mirrors HeroCore.astro fluid=false fixed sizes exactly (the same sizes
    // the /share/[week] route renders at), so the canvas output is pixel-
    // equivalent to the HTML hero with the week's date stamped in.
    const W = 1080;
    const H = 1080;
    const cream = '#f4f2d9';
    const aubergine = '#2E1F2F';

    ctx.fillStyle = cream;
    ctx.fillRect(0, 0, W, H);
    ctx.textAlign = 'center';
    ctx.textBaseline = 'alphabetic';

    // Vertical layout mirrors HeroCore: banner → KINDERHOOK → FARMERS → MARKET
    // → divider → schedule → time, stacked centered. Starting y lets the whole
    // block sit visually centered on the 1080 canvas with room below for the
    // extra tagline + CTA.
    let y = 150;

    // Sunflower banner — 360 wide, aspect 320/123 per the source asset.
    const bw = 360;
    const bh = bw * (123 / 320);
    drawTinted(banner.img, (W - bw) / 2, y, bw, bh, aubergine);
    y += bh - 4; // HeroCore uses -mb-1 to let the banner kiss the title

    // KINDERHOOK — 64px PP Gatwick Bold, tracking ~0.08em
    ctx.fillStyle = aubergine;
    ctx.font = '700 64px "PP Gatwick", Georgia, serif';
    ctx.letterSpacing = '5px'; // ~0.08em
    y += 64; // baseline
    ctx.fillText('KINDERHOOK', W / 2, y);
    y += 8; // HeroCore `my-1` on FARMERS ≈ 8px top margin

    // FARMERS — farmers-clean.svg, 640 wide, aspect 1384/288
    const fw = 640;
    const fh = fw * (288 / 1384);
    drawTinted(farmers.img, (W - fw) / 2, y, fw, fh, aubergine);
    y += fh + 8; // `my-1` bottom

    // MARKET — 52px PP Gatwick Bold, tracking ~0.1em
    ctx.font = '700 52px "PP Gatwick", Georgia, serif';
    ctx.letterSpacing = '5px';
    y += 52;
    ctx.fillText('MARKET', W / 2, y);
    y += 16; // HeroCore divider `mt-4`

    // Hand-drawn divider — FM-DIVIDER_2.png, 520 wide, aspect 20/1
    const dw = 520;
    const dh = dw / 20;
    drawTinted(divider.img, (W - dw) / 2, y, dw, dh, aubergine);
    y += dh + 32; // `mb-8`

    // Specific date — slots in where HeroCore renders scheduleText.
    ctx.letterSpacing = '2px';
    ctx.font = '700 32px "DM Serif Display", Georgia, serif';
    y += 32;
    ctx.fillText(displayDate.toUpperCase(), W / 2, y);
    y += 16; // `mb-4`

    // Time
    ctx.letterSpacing = '0px';
    ctx.font = '400 44px "DM Serif Display", Georgia, serif';
    y += 44;
    ctx.fillText('8:30 AM – 12:30 PM', W / 2, y);

    // ── Below the hero block: tagline + CTA ────────────────────────────────
    y += 64;
    ctx.font = '400 26px "Lora", Georgia, serif';
    y = wrapText(
      'Fresh local produce, artisan goods, and live music in the heart of the Hudson Valley.',
      W / 2, y, 820, 38
    );

    y += 60;
    ctx.font = '700 24px "DM Serif Display", Georgia, serif';
    ctx.letterSpacing = '2px';
    ctx.fillText('♥  FOLLOW FOR WEEKLY UPDATES  ♥', W / 2, y);

    // Subtle URL footer
    ctx.letterSpacing = '0px';
    ctx.fillStyle = 'rgba(46, 31, 47, 0.55)';
    ctx.font = '400 20px "Lora", Georgia, serif';
    ctx.fillText('kinderhookfarmersmarket.com  ·  Rain or Shine', W / 2, H - 40);
  }

  // Instagram button → same flow as download (Instagram has no web share URL scheme)
  const instagramBtn = document.getElementById('share-instagram-btn');
  if (instagramBtn) {
    instagramBtn.addEventListener('click', () => downloadBtn.click());
  }

  // Build the caption text that rides along with the image when the user
  // invokes the native share sheet. Since the image itself is the clean hero,
  // everything the image *doesn't* include — theme, music, location — lives
  // in the caption so it still travels with the post.
  function buildShareText() {
    const parts = [
      `Kinderhook Farmers Market — ${displayDate}`,
      '8:30 AM – 12:30 PM · Village Green, Kinderhook NY',
    ];
    if (theme) parts.push(theme);
    if (music && music.name) {
      parts.push(`Live music: ${music.name}${music.time ? ' · ' + music.time : ''}`);
    }
    parts.push('See you there! #KinderhookFarmersMarket');
    return parts.join('\n');
  }

  downloadBtn.addEventListener('click', async () => {
    await generateCard();

    const filename = `kinderhook-market-${date}.png`;

    canvas.toBlob(async (blob) => {
      if (!blob) return;

      const file = new File([blob], filename, { type: 'image/png' });

      if (navigator.share && navigator.canShare && navigator.canShare({ files: [file] })) {
        try {
          await navigator.share({
            files: [file],
            title: 'Kinderhook Farmers Market',
            text: buildShareText(),
          });
          return;
        } catch (err) {
          if (err.name === 'AbortError') return;
        }
      }

      const link = document.createElement('a');
      link.download = filename;
      link.href = URL.createObjectURL(blob);
      link.click();
      URL.revokeObjectURL(link.href);
    }, 'image/png');
  });
</script>
