---
interface Props {
  date: string;
  displayDate: string;
  theme?: string;
  music?: { name: string; time: string };
}

const { date, displayDate, theme, music } = Astro.props;
const base = import.meta.env.BASE_URL;

// Canonical share URL + message
const shareUrl = 'https://harmonicsystems.github.io/market/';
const shareText = `Kinderhook Farmers Market — ${displayDate}, 8:30 AM–12:30 PM on the Village Green.${theme ? ' ' + theme + '.' : ''} See you there!`;

const facebookShareUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`;
const nextdoorShareUrl = `https://nextdoor.com/sharekit/?source=external&body=${encodeURIComponent(shareText)}&url=${encodeURIComponent(shareUrl)}`;

// Break displayDate into day + date for bigger typography
// "Saturday, May 9, 2026" → day="Saturday" date="May 9, 2026"
const commaIdx = displayDate.indexOf(',');
const dayName = commaIdx > 0 ? displayDate.slice(0, commaIdx) : '';
const dateRest = commaIdx > 0 ? displayDate.slice(commaIdx + 1).trim() : displayDate;
---

<div class="shareable-card-container flex flex-wrap items-center justify-center gap-4">
  <canvas id="market-card-canvas" width="1080" height="1080" class="hidden"></canvas>

  <p class="font-display font-bold text-black text-lg md:text-xl uppercase tracking-widest">Share the Market:</p>

  <div class="flex flex-wrap justify-center items-center gap-4">
    <a
      href={facebookShareUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center justify-center hover:opacity-80 transition-opacity"
      aria-label="Share on Facebook"
    >
      <span class="social-icon-mask block w-10 h-10 md:w-12 md:h-12" style={`background-color: #2E1F2F; -webkit-mask-image: url('${base}/icons/FM-FACEBOOK-ICON.png'); mask-image: url('${base}/icons/FM-FACEBOOK-ICON.png');`}></span>
    </a>

    <a
      href={nextdoorShareUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center justify-center hover:opacity-80 transition-opacity"
      aria-label="Share on Nextdoor"
    >
      <span class="social-icon-mask block w-10 h-10 md:w-12 md:h-12" style={`background-color: #2E1F2F; -webkit-mask-image: url('${base}/icons/FM-NEXTDOOR-ICON.png'); mask-image: url('${base}/icons/FM-NEXTDOOR-ICON.png');`}></span>
    </a>

    <button
      type="button"
      id="share-instagram-btn"
      class="inline-flex items-center justify-center hover:opacity-80 transition-opacity"
      aria-label="Download image to share on Instagram"
    >
      <span class="social-icon-mask block w-10 h-10 md:w-12 md:h-12" style={`background-color: #2E1F2F; -webkit-mask-image: url('${base}/icons/FM-INSTAGRAM-ICON.png'); mask-image: url('${base}/icons/FM-INSTAGRAM-ICON.png');`}></span>
    </button>

    <button
      id="download-card-btn"
      type="button"
      class="inline-flex items-center justify-center hover:opacity-80 transition-opacity"
      aria-label="Save share image"
    >
      <span class="social-icon-mask block w-10 h-10 md:w-12 md:h-12" style={`background-color: #2E1F2F; -webkit-mask-image: url('${base}/icons/FM-DOWNLOAD-ICON.png'); mask-image: url('${base}/icons/FM-DOWNLOAD-ICON.png');`}></span>
    </button>
  </div>
</div>

<script define:vars={{ date, displayDate, theme, music, base }}>
  const canvas = document.getElementById('market-card-canvas');
  const ctx = canvas.getContext('2d');
  const downloadBtn = document.getElementById('download-card-btn');

  // Break displayDate for layout: "Saturday, May 9, 2026" → "Saturday" + "May 9, 2026"
  const commaIdx = displayDate.indexOf(',');
  const dayName = commaIdx > 0 ? displayDate.slice(0, commaIdx) : '';
  const dateRest = commaIdx > 0 ? displayDate.slice(commaIdx + 1).trim() : displayDate;

  // Load the static sunflower banner (matches preview).
  // Note: do NOT set crossOrigin — the asset is same-origin, and setting
  // crossOrigin="anonymous" can silently fail on static hosts that don't
  // send CORS headers, leaving bannerImg.complete=true but the image
  // unrenderable onto the canvas.
  const bannerImg = new Image();
  const bannerSrc = (base || '/').replace(/\/$/, '') + '/icons/FM-SUNFLOWER-TOP_BANNER-STATIC.png';
  const bannerReady = new Promise((resolve) => {
    bannerImg.onload = () => resolve(true);
    bannerImg.onerror = () => resolve(false);
  });
  bannerImg.src = bannerSrc;

  async function generateCard() {
    // Make sure the banner has finished loading before we try to draw it.
    await bannerReady;
    if (bannerImg.decode) {
      try { await bannerImg.decode(); } catch {}
    }
    const w = 1080;
    const h = 1080;
    const aubergine = '#2E1F2F';
    const gold = '#DFA926';
    const darkGold = '#B8860B';

    ctx.textAlign = 'center';

    // ═══ HEADER: Aubergine with banner + stacked KINDERHOOK / FARMERS MARKET ═══
    const headerH = 460;
    ctx.fillStyle = aubergine;
    ctx.fillRect(0, 0, w, headerH);

    // Banner (sunflower + leaves) — tinted gold, centered
    if (bannerImg.complete && bannerImg.naturalWidth > 0) {
      const bannerW = 520;
      const bannerH = bannerW * (bannerImg.naturalHeight / bannerImg.naturalWidth);
      const bannerX = (w - bannerW) / 2;
      const bannerY = 40;

      const tmpCanvas = document.createElement('canvas');
      tmpCanvas.width = bannerW;
      tmpCanvas.height = bannerH;
      const tmpCtx = tmpCanvas.getContext('2d');
      tmpCtx.drawImage(bannerImg, 0, 0, bannerW, bannerH);
      tmpCtx.globalCompositeOperation = 'source-in';
      tmpCtx.fillStyle = gold;
      tmpCtx.fillRect(0, 0, bannerW, bannerH);
      ctx.drawImage(tmpCanvas, bannerX, bannerY);
    }

    // KINDERHOOK — big, gold, Aoboshi One
    ctx.fillStyle = gold;
    ctx.font = '400 96px Aoboshi One, Georgia, serif';
    ctx.fillText('KINDERHOOK', w / 2, 320);

    // FARMERS MARKET — smaller (mirrors hero proportions ~72%)
    ctx.font = '400 68px Aoboshi One, Georgia, serif';
    ctx.fillText('FARMERS MARKET', w / 2, 400);

    // ═══ BODY: Gold, spacious, day+date on one line ═══
    ctx.fillStyle = gold;
    ctx.fillRect(0, headerH, w, h - headerH);

    // Day + Date on one line
    const dayDate = dayName ? `${dayName}, ${dateRest}` : dateRest;
    ctx.fillStyle = aubergine;
    ctx.font = 'bold 76px DM Serif Display, Georgia, serif';
    ctx.fillText(dayDate, w / 2, headerH + 140);

    // Time + Location
    ctx.fillStyle = 'rgba(46, 31, 47, 0.7)';
    ctx.font = '400 36px Lora, Georgia, serif';
    ctx.fillText('8:30 AM – 12:30 PM  ·  Village Green', w / 2, headerH + 200);

    // Theme (no music)
    if (theme) {
      ctx.fillStyle = aubergine;
      ctx.font = 'bold 60px DM Serif Display, Georgia, serif';
      ctx.fillText(theme, w / 2, headerH + 320);
    }

    // Footer — subtle location line
    ctx.fillStyle = 'rgba(46, 31, 47, 0.5)';
    ctx.font = '500 26px Lora, Georgia, serif';
    ctx.fillText('KINDERHOOK, NY  ·  RAIN OR SHINE', w / 2, h - 80);

    // URL — very subtle
    ctx.fillStyle = 'rgba(46, 31, 47, 0.3)';
    ctx.font = '400 22px Lora, Georgia, serif';
    ctx.fillText('kinderhookfarmersmarket.com', w / 2, h - 40);
  }

  // Instagram button → same flow as download (Instagram has no web share URL scheme)
  const instagramBtn = document.getElementById('share-instagram-btn');
  if (instagramBtn) {
    instagramBtn.addEventListener('click', () => downloadBtn.click());
  }

  downloadBtn.addEventListener('click', async () => {
    await generateCard();

    const filename = `kinderhook-market-${date}.png`;

    canvas.toBlob(async (blob) => {
      if (!blob) return;

      const file = new File([blob], filename, { type: 'image/png' });

      if (navigator.share && navigator.canShare && navigator.canShare({ files: [file] })) {
        try {
          await navigator.share({
            files: [file],
            title: 'Kinderhook Farmers Market',
            text: `Join us at the Kinderhook Farmers Market - ${displayDate}!`
          });
          return;
        } catch (err) {
          if (err.name === 'AbortError') return;
        }
      }

      const link = document.createElement('a');
      link.download = filename;
      link.href = URL.createObjectURL(blob);
      link.click();
      URL.revokeObjectURL(link.href);
    }, 'image/png');
  });
</script>
