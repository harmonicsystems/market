---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import StructuredData from '../components/StructuredData.astro';

interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  ogImageAlt?: string;
  canonicalPath?: string;
}

const {
  title,
  description = "Kinderhook Farmers Market in the Hudson Valley — fresh local produce, artisan goods, baked goods, and community spirit every Saturday on the Village Green in Kinderhook, Columbia County, NY. Open May through October.",
  ogType = 'website',
  ogImage,
  ogImageAlt,
  canonicalPath,
} = Astro.props;

// Get base URL for all internal links
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO
      title={title}
      description={description}
      type={ogType}
      image={ogImage}
      imageAlt={ogImageAlt}
      canonicalPath={canonicalPath}
    />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Aoboshi+One&family=DM+Serif+Display:ital@0;1&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <title>{title} | Kinderhook Farmers Market - Hudson Valley, NY</title>
    <StructuredData type="organization" />
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <div role="note" class="bg-black text-cream text-center text-xs md:text-sm px-4 py-2 font-display tracking-wide">
      <strong class="font-bold uppercase tracking-widest">Work in Progress:</strong>
      <span class="opacity-90">This site is for demonstration only &mdash; information may not be accurate.</span>
    </div>

    <header class="bg-cream sticky top-0 z-50">
      <nav class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href={base} id="header-logo" class="font-logo text-sm md:text-base tracking-wide text-black uppercase opacity-0 transition-opacity duration-300">
          Kinderhook Farmers Market
        </a>

        <ul class="hidden md:flex items-center gap-6 font-display font-semibold text-sm tracking-wide text-black">
          <li><a href={`${base}/vendors`} class="hover:underline decoration-2 underline-offset-4">Vendors</a></li>
          <li><a href={`${base}/discover`} class="hover:underline decoration-2 underline-offset-4">Discover</a></li>
          <li><a href={`${base}/visit`} class="hover:underline decoration-2 underline-offset-4">Visit</a></li>
          <li><a href={`${base}/about`} class="hover:underline decoration-2 underline-offset-4">About</a></li>
          <li><a href={`${base}/contact`} class="bg-black text-cream px-4 py-2 rounded-md hover:bg-black/85 transition-colors">Contact</a></li>
        </ul>

        <button class="md:hidden p-2 text-black" aria-label="Open menu" id="mobile-menu-btn">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </nav>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden bg-cream border-t border-black/20">
        <ul class="flex flex-col p-4 gap-2 font-display font-semibold tracking-wide text-base text-black">
          <li><a href={`${base}/vendors`} class="block py-3 px-3 rounded-md hover:bg-black hover:text-cream transition-colors">Vendors</a></li>
          <li><a href={`${base}/discover`} class="block py-3 px-3 rounded-md hover:bg-black hover:text-cream transition-colors">Discover Kinderhook</a></li>
          <li><a href={`${base}/visit`} class="block py-3 px-3 rounded-md hover:bg-black hover:text-cream transition-colors">Plan Your Visit</a></li>
          <li><a href={`${base}/about`} class="block py-3 px-3 rounded-md hover:bg-black hover:text-cream transition-colors">About</a></li>
          <li><a href={`${base}/contact`} class="block py-3 px-3 rounded-md bg-black text-cream hover:bg-black/85 transition-colors">Contact</a></li>
        </ul>
      </div>
    </header>

    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <footer class="bg-black text-white mt-auto">
      <div class="max-w-6xl mx-auto px-4 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <h3 class="font-logo text-lg tracking-wide uppercase mb-4">Kinderhook Farmers Market</h3>
            <p class="text-white/80 mb-2">Village Green, Broad Street &amp; Albany Avenue</p>
            <p class="text-white/80 mb-2">Kinderhook, NY 12106</p>
            <p class="text-white/80">Saturdays 8:30am - 12:30pm</p>
            <p class="text-white/60 text-sm mt-2">May through October</p>
          </div>

          <div>
            <h3 class="font-display font-bold text-xl mb-4">Quick Links</h3>
            <ul class="space-y-2 text-white/80">
              <li><a href={`${base}/vendors`} class="hover:text-orange transition-colors">Our Vendors</a></li>
              <li><a href={`${base}/discover`} class="hover:text-orange transition-colors">Discover Kinderhook</a></li>
              <li><a href={`${base}/businesses`} class="hover:text-orange transition-colors">Business Directory</a></li>
              <li><a href={`${base}/visit`} class="hover:text-orange transition-colors">Plan Your Visit</a></li>
              <li><a href={`${base}/recipes`} class="hover:text-orange transition-colors">Recipes</a></li>
            </ul>
          </div>

          <div>
            <h3 class="font-display font-bold text-xl mb-4">Connect</h3>
            <a
              href="https://www.facebook.com/KinderhookFarmersMarket"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-white/80 hover:text-orange transition-colors"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
              </svg>
              Follow us on Facebook
            </a>
            <p class="mt-4 text-white/60 text-sm">
              Sponsored by the Kinderhook Business and Professional Association
            </p>
          </div>
        </div>

        <div class="border-t border-white/20 mt-8 pt-8 text-center text-white/60 text-sm">
          <p>&copy; {new Date().getFullYear()} Kinderhook Farmers Market. All rights reserved.</p>
        </div>
      </div>
    </footer>

    <script>
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');

      menuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
      });

      // Show header logo after scrolling past homepage hero
      const headerLogo = document.getElementById('header-logo');
      const homepageHero = document.getElementById('homepage-hero');

      if (headerLogo && homepageHero) {
        // Homepage: hide logo until scrolled past hero
        const observer = new IntersectionObserver(
          ([entry]) => {
            if (entry.isIntersecting) {
              headerLogo.classList.add('opacity-0');
              headerLogo.classList.remove('opacity-100');
            } else {
              headerLogo.classList.remove('opacity-0');
              headerLogo.classList.add('opacity-100');
            }
          },
          { threshold: 0, rootMargin: '-60px 0px 0px 0px' }
        );
        observer.observe(homepageHero);
      } else if (headerLogo) {
        // All other pages: always show the logo
        headerLogo.classList.remove('opacity-0');
        headerLogo.classList.add('opacity-100');
      }
    </script>
  </body>
</html>
