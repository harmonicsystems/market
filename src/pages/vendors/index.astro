---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StructuredData from '../../components/StructuredData.astro';
import MarketIcon from '../../components/MarketIcon.astro';
import { getCollection } from 'astro:content';
import weeklyVendors from '../../data/weekly-vendors.json';

const allVendors = (await getCollection('vendors')).filter((v) => v.data.active);
const base = import.meta.env.BASE_URL;

// Build a name-based lookup so roster entries can be enriched with content-collection data.
function normalize(s: string) {
  return s
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, ' ')
    .trim();
}
const vendorByName = new Map<string, (typeof allVendors)[number]>();
for (const v of allVendors) {
  vendorByName.set(normalize(v.data.name), v);
  vendorByName.set(normalize(v.data.slug), v);
}

type RosterEntry =
  | { kind: 'rich'; name: string; note?: string; category?: string; vendor: (typeof allVendors)[number] }
  | { kind: 'plain'; name: string; note?: string; category?: string };

function resolveEntry(raw: string | { name: string; slug?: string; note?: string; category?: string }): RosterEntry {
  const name = typeof raw === 'string' ? raw : raw.name;
  const note = typeof raw === 'object' ? raw.note : undefined;
  const slug = typeof raw === 'object' ? raw.slug : undefined;
  const category = typeof raw === 'object' ? raw.category : undefined;
  const norm = normalize(name);
  const match =
    (slug && allVendors.find((v) => v.data.slug === slug)) ||
    vendorByName.get(norm) ||
    // Prefix match: roster "Courtney Aison" matches content "Courtney Aison Pottery"
    allVendors.find((v) => {
      const vn = normalize(v.data.name);
      return vn.startsWith(norm + ' ') || norm.startsWith(vn + ' ');
    });
  return match ? { kind: 'rich', name, note, category, vendor: match } : { kind: 'plain', name, note, category };
}

const weekly = weeklyVendors.vendors.map(resolveEntry);
const returning = weeklyVendors.returningInMayOrJune.map(resolveEntry);
const occasional = weeklyVendors.occasional.map(resolveEntry);

// Group weekly vendors by category, preserving JSON order.
const weeklyCategoryOrder: string[] = [];
const weeklyByCategory: Record<string, RosterEntry[]> = {};
for (const entry of weekly) {
  const cat = entry.category ?? 'Other';
  if (!weeklyByCategory[cat]) {
    weeklyByCategory[cat] = [];
    weeklyCategoryOrder.push(cat);
  }
  weeklyByCategory[cat].push(entry);
}

const categoryIcon: Record<string, string> = {
  'From the Farm': 'apple',
  'Food & Drink': 'apple',
  'Home & Body': 'brush',
  'Community': 'heart',
  'Other': 'star',
};

const categoryLabels: Record<string, string> = {
  'baked-goods': 'Baked Goods',
  sweets: 'Sweets',
  honey: 'Honey',
  'specialty-foods': 'Specialty Foods',
  crafts: 'Crafts',
  pottery: 'Pottery',
  'home-goods': 'Home Goods',
  'prepared-foods': 'Prepared Foods',
  bbq: 'BBQ',
  international: 'International',
  produce: 'Produce',
  farm: 'Farm Fresh',
};
---

<BaseLayout
  title="Our Vendors"
  description="Meet the farmers, bakers, artisans, and makers at the Kinderhook Farmers Market in Columbia County, NY. 14 weekly vendors plus rotating guests from the Hudson Valley every Saturday, May through October."
  canonicalPath="/vendors"
>
  <StructuredData slot="head" type="breadcrumb" data={{ items: [{ name: 'Home', url: '/' }, { name: 'Vendors', url: '/vendors' }] }} />

  <section class="bg-cream py-12">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h1 class="font-display font-bold text-4xl md:text-5xl text-black mb-4">Our Vendors</h1>
        <p class="text-black text-lg max-w-2xl mx-auto">
          Meet the farmers, artisans, and makers who bring the best of the Hudson Valley to Kinderhook every Saturday.
        </p>
      </div>

      {/* ── Weekly Vendors — grouped by category ───────────────────────── */}
      <div class="mb-16">
        <h2 class="font-display font-bold text-2xl text-black mb-2 flex items-center gap-3">
          <span class="text-sm px-3 py-1 rounded-md bg-orange text-cream">Weekly</span>
          Weekly Vendors
        </h2>
        <p class="text-black/80 text-sm mb-8">Here every Saturday of the 2026 season.</p>

        <div class="space-y-8">
          {weeklyCategoryOrder.map((cat) => {
            const entries = weeklyByCategory[cat];
            const rich = entries.filter((e) => e.kind === 'rich');
            const plain = entries.filter((e) => e.kind === 'plain');
            return (
              <div>
                <h3 class="font-logo uppercase tracking-[0.08em] text-sm text-black/70 mb-4 flex items-center gap-2 pb-2 border-b border-black/10">
                  <MarketIcon name={categoryIcon[cat] || 'star'} class="w-5 h-5 shrink-0" />
                  {cat}
                </h3>

                {rich.length > 0 && (
                  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-4">
                    {rich.map((entry: any) => (
                      <article class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition-shadow">
                        <a href={`${base}/vendors/${entry.vendor.data.slug}`} class="block">
                          <div class="h-40 bg-gradient-to-br from-orange/20 to-cream flex items-center justify-center">
                            <span class="opacity-30"><MarketIcon name="apple" class="w-16 h-16" /></span>
                          </div>
                        </a>
                        <div class="p-6">
                          <h4 class="font-display font-bold text-xl text-black mb-1">
                            <a href={`${base}/vendors/${entry.vendor.data.slug}`} class="hover:text-orange transition-colors">
                              {entry.name}
                            </a>
                          </h4>
                          {entry.vendor.data.tagline && (
                            <p class="text-black text-sm font-medium mb-3">{entry.vendor.data.tagline}</p>
                          )}
                          {entry.note && <p class="text-black/70 text-xs italic mb-3">{entry.note}</p>}
                          {entry.vendor.data.description && (
                            <p class="text-black text-sm mb-4">{entry.vendor.data.description}</p>
                          )}
                          <div class="flex flex-wrap gap-2">
                            {entry.vendor.data.categories.map((c: string) => (
                              <span class="bg-cream text-black text-xs px-2 py-1 rounded-md">
                                {categoryLabels[c] || c}
                              </span>
                            ))}
                          </div>
                        </div>
                      </article>
                    ))}
                  </div>
                )}

                {plain.length > 0 && (
                  <ul class="flex flex-wrap gap-2">
                    {plain.map((entry: any) => (
                      <li class="bg-white rounded-md px-4 py-2 shadow-sm">
                        <span class="font-display font-medium text-black">{entry.name}</span>
                        {entry.note && <span class="text-black/60 text-xs italic ml-1">— {entry.note}</span>}
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            );
          })}
        </div>
      </div>

      {/* ── Returning / Occasional — flat lists ─────────────────────────── */}
      {[
        {
          heading: 'Returning in May / June',
          subheading: 'Favorites returning as their seasons get underway.',
          badge: 'Returning',
          badgeClass: 'bg-purple text-cream',
          rich: returning.filter((e) => e.kind === 'rich'),
          plain: returning.filter((e) => e.kind === 'plain'),
        },
        {
          heading: 'Occasional Vendors Throughout the Season',
          subheading: "Watch the weekly lineup to see who's dropping in.",
          badge: 'Rotating',
          badgeClass: 'bg-black text-cream',
          rich: occasional.filter((e) => e.kind === 'rich'),
          plain: occasional.filter((e) => e.kind === 'plain'),
        },
      ].map((section) => (
        <div class="mb-16">
          <h2 class="font-display font-bold text-2xl text-black mb-2 flex items-center gap-3">
            <span class={`text-sm px-3 py-1 rounded-md ${section.badgeClass}`}>{section.badge}</span>
            {section.heading}
          </h2>
          <p class="text-black/80 text-sm mb-6">{section.subheading}</p>

          {section.rich.length > 0 && (
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-6">
              {section.rich.map((entry: any) => (
                <article class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition-shadow">
                  <a href={`${base}/vendors/${entry.vendor.data.slug}`} class="block">
                    <div class="h-40 bg-gradient-to-br from-orange/20 to-cream flex items-center justify-center">
                      <span class="opacity-30"><MarketIcon name="apple" class="w-16 h-16" /></span>
                    </div>
                  </a>
                  <div class="p-6">
                    <h3 class="font-display font-bold text-xl text-black mb-1">
                      <a href={`${base}/vendors/${entry.vendor.data.slug}`} class="hover:text-orange transition-colors">
                        {entry.name}
                      </a>
                    </h3>
                    {entry.vendor.data.tagline && (
                      <p class="text-black text-sm font-medium mb-3">{entry.vendor.data.tagline}</p>
                    )}
                    {entry.note && <p class="text-black/70 text-xs italic mb-3">{entry.note}</p>}
                    {entry.vendor.data.description && (
                      <p class="text-black text-sm mb-4">{entry.vendor.data.description}</p>
                    )}
                    <div class="flex flex-wrap gap-2">
                      {entry.vendor.data.categories.map((cat: string) => (
                        <span class="bg-cream text-black text-xs px-2 py-1 rounded-md">
                          {categoryLabels[cat] || cat}
                        </span>
                      ))}
                    </div>
                  </div>
                </article>
              ))}
            </div>
          )}

          {section.plain.length > 0 && (
            <ul class="flex flex-wrap gap-2">
              {section.plain.map((entry: any) => (
                <li class="bg-white rounded-md px-4 py-2 shadow-sm">
                  <span class="font-display font-medium text-black">{entry.name}</span>
                  {entry.note && <span class="text-black/60 text-xs italic ml-1">— {entry.note}</span>}
                </li>
              ))}
            </ul>
          )}
        </div>
      ))}

      {/* Become a Vendor CTA */}
      <div class="mt-8 bg-white rounded-xl p-8 text-center shadow-md">
        <h2 class="font-display font-bold text-2xl text-black mb-4">Interested in Becoming a Vendor?</h2>
        <p class="text-black mb-6 max-w-xl mx-auto">
          We're always looking for local farmers, artisans, and food producers to join our market family.
        </p>
        <a href={`${base}/contact`} class="inline-block bg-orange text-cream font-display font-bold px-6 py-3 rounded-md hover:bg-orange/90 transition-colors">
          Apply to Vend
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
