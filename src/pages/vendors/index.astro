---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StructuredData from '../../components/StructuredData.astro';
import MarketIcon from '../../components/MarketIcon.astro';
import { getCollection } from 'astro:content';

const allVendors = await getCollection('vendors');
const regularVendors = allVendors.filter(v => v.data.vendorType === 'regular');
const guestVendors = allVendors.filter(v => v.data.vendorType === 'guest');

// Category labels
const base = import.meta.env.BASE_URL;

const categoryLabels: Record<string, string> = {
  'baked-goods': 'Baked Goods',
  'sweets': 'Sweets',
  'honey': 'Honey',
  'specialty-foods': 'Specialty Foods',
  'crafts': 'Crafts',
  'pottery': 'Pottery',
  'home-goods': 'Home Goods',
  'prepared-foods': 'Prepared Foods',
  'bbq': 'BBQ',
  'international': 'International',
  'produce': 'Produce',
  'farm': 'Farm Fresh',
};
---

<BaseLayout
  title="Our Vendors"
  description="Meet the local farmers, bakers, artisans, and makers at the Kinderhook Farmers Market in Columbia County, NY. Fresh produce, baked goods, honey, pottery, prepared foods, and crafts from Hudson Valley producers every Saturday."
  canonicalPath="/vendors"
>
  <StructuredData slot="head" type="breadcrumb" data={{ items: [{ name: 'Home', url: '/' }, { name: 'Vendors', url: '/vendors' }] }} />
  <section class="bg-cream py-12">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h1 class="font-display font-bold text-4xl md:text-5xl text-black mb-4">
          Our Vendors
        </h1>
        <p class="text-black/90 text-lg max-w-2xl mx-auto">
          Meet the farmers, artisans, and makers who bring the best of the Hudson Valley to Kinderhook every Saturday.
        </p>
      </div>

      <!-- Regular Vendors -->
      <div class="mb-16">
        <h2 class="font-display font-bold text-2xl text-black mb-6 flex items-center gap-3">
          <span class="bg-orange text-white text-sm px-3 py-1 rounded-md">Weekly</span>
          Regular Vendors
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {regularVendors.map((vendor) => (
            <article class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition-shadow">
              <a href={`${base}/vendors/${vendor.data.slug}`} class="block">
                <div class="h-48 bg-gradient-to-br from-orange/20 to-orange/20 flex items-center justify-center">
                  <span class="opacity-30"><MarketIcon name="apple" class="w-16 h-16" /></span>
                </div>
              </a>
              <div class="p-6">
                <h3 class="font-display font-bold text-xl text-black mb-1">
                  <a href={`${base}/vendors/${vendor.data.slug}`} class="hover:text-orange transition-colors">
                    {vendor.data.name}
                  </a>
                </h3>
                <p class="text-purple text-sm font-medium mb-3">{vendor.data.tagline}</p>
                <p class="text-black/70 text-sm mb-4">{vendor.data.description}</p>
                <div class="flex flex-wrap gap-2">
                  {vendor.data.categories.map((cat: string) => (
                    <span class="bg-cream text-black/70 text-xs px-2 py-1 rounded-md">
                      {categoryLabels[cat] || cat}
                    </span>
                  ))}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <!-- Guest Vendors -->
      <div>
        <h2 class="font-display font-bold text-2xl text-black mb-6 flex items-center gap-3">
          <span class="bg-orange text-white text-sm px-3 py-1 rounded-md">Rotating</span>
          Guest Vendors
        </h2>
        <p class="text-black/70 mb-6">
          These talented vendors join us on select Saturdays throughout the season. Check our weekly announcements to see who's coming!
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {guestVendors.map((vendor) => (
            <article class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition-shadow border-2 border-orange/20">
              <a href={`${base}/vendors/${vendor.data.slug}`} class="block">
                <div class="h-48 bg-gradient-to-br from-orange/20 to-cream flex items-center justify-center">
                  <span class="opacity-30"><MarketIcon name="sunflower" class="w-16 h-16" /></span>
                </div>
              </a>
              <div class="p-6">
                <h3 class="font-display font-bold text-xl text-black mb-1">
                  <a href={`${base}/vendors/${vendor.data.slug}`} class="hover:text-orange transition-colors">
                    {vendor.data.name}
                  </a>
                </h3>
                <p class="text-purple text-sm font-medium mb-3">{vendor.data.tagline}</p>
                <p class="text-black/70 text-sm mb-4">{vendor.data.description}</p>
                <div class="flex flex-wrap gap-2">
                  {vendor.data.categories.map((cat: string) => (
                    <span class="bg-cream text-black/70 text-xs px-2 py-1 rounded-md">
                      {categoryLabels[cat] || cat}
                    </span>
                  ))}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <!-- Become a Vendor CTA -->
      <div class="mt-16 bg-white rounded-xl p-8 text-center shadow-md">
        <h2 class="font-display font-bold text-2xl text-black mb-4">
          Interested in Becoming a Vendor?
        </h2>
        <p class="text-black/70 mb-6 max-w-xl mx-auto">
          We're always looking for local farmers, artisans, and food producers to join our market family.
        </p>
        <a href={`${base}/contact`} class="inline-block bg-orange text-white font-display font-bold px-6 py-3 rounded-md hover:bg-orange/90 transition-colors">
          Apply to Vend
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
