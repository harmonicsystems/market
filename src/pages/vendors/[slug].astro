---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StructuredData from '../../components/StructuredData.astro';
import { getCollection, render } from 'astro:content';

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const vendors = await getCollection('vendors');
  const allRecipes = await getCollection('recipes');
  const allVendors = vendors.filter(v => v.data.active);

  return allVendors.map((vendor) => {
    // Find recipes contributed by this vendor
    const vendorRecipes = allRecipes.filter(r =>
      r.data.contributor && vendor.data.name.toLowerCase().includes(r.data.contributor.toLowerCase().split(' ')[0])
      || r.data.contributor?.toLowerCase().includes(vendor.data.name.toLowerCase().split(' ')[0])
    );

    // Find related vendors (overlapping categories, excluding self)
    const related = allVendors
      .filter(v => v.data.slug !== vendor.data.slug)
      .map(v => ({
        vendor: v,
        overlap: v.data.categories.filter((c: string) => vendor.data.categories.includes(c)).length,
      }))
      .sort((a, b) => b.overlap - a.overlap)
      .slice(0, 3)
      .map(r => r.vendor);

    return {
      params: { slug: vendor.data.slug },
      props: { vendor, vendorRecipes, relatedVendors: related },
    };
  });
}

const { vendor, vendorRecipes, relatedVendors } = Astro.props;
const { Content } = await render(vendor);

const categoryLabels: Record<string, string> = {
  'baked-goods': 'Baked Goods',
  'sweets': 'Sweets',
  'honey': 'Honey',
  'specialty-foods': 'Specialty Foods',
  'crafts': 'Crafts',
  'pottery': 'Pottery',
  'home-goods': 'Home Goods',
  'prepared-foods': 'Prepared Foods',
  'bbq': 'BBQ',
  'international': 'International',
  'produce': 'Produce',
  'farm': 'Farm Fresh',
  'fruit': 'Fruit',
  'cider': 'Cider',
  'cookies': 'Cookies',
  'body-care': 'Body Care',
  'wellness': 'Wellness',
  'flowers': 'Flowers',
  'plants': 'Plants',
  'eggs': 'Eggs',
  'meat': 'Meat',
};
---

<BaseLayout
  title={vendor.data.name}
  description={`${vendor.data.tagline || vendor.data.name} — find them at the Kinderhook Farmers Market in Columbia County, NY. ${vendor.data.description || ''}`}
  canonicalPath={`/vendors/${vendor.data.slug}`}
>
  <StructuredData slot="head" type="vendor" data={vendor.data} />
  <StructuredData slot="head" type="breadcrumb" data={{ items: [
    { name: 'Home', url: '/' },
    { name: 'Vendors', url: '/vendors' },
    { name: vendor.data.name, url: `/vendors/${vendor.data.slug}` },
  ] }} />

  <article class="bg-cream py-12">
    <div class="max-w-3xl mx-auto px-4">
      <!-- Back link -->
      <a href={`${base}/vendors`} class="inline-flex items-center gap-2 text-orange font-semibold hover:underline mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        All Vendors
      </a>

      <!-- Hero -->
      <header class="mb-8">
        <div class="flex flex-wrap gap-2 mb-4">
          <span class={`text-sm px-3 py-1 rounded-md font-medium ${vendor.data.vendorType === 'regular' ? 'bg-orange text-cream' : 'bg-purple text-cream'}`}>
            {vendor.data.vendorType === 'regular' ? 'Weekly Vendor' : 'Guest Vendor'}
          </span>
          {vendor.data.categories.map((cat: string) => (
            <span class="bg-cream text-black text-sm px-3 py-1 rounded-md">
              {categoryLabels[cat] || cat}
            </span>
          ))}
        </div>
        <h1 class="font-display font-bold text-3xl md:text-4xl text-black mb-2">
          {vendor.data.name}
        </h1>
        {vendor.data.tagline && (
          <p class="text-black font-display font-semibold text-lg mb-4">{vendor.data.tagline}</p>
        )}
        {vendor.data.description && (
          <p class="text-black text-lg">{vendor.data.description}</p>
        )}
      </header>

      <!-- About / Full description -->
      <div class="bg-white rounded-xl shadow-md p-6 md:p-8 mb-8">
        <div class="prose prose-lg max-w-none prose-headings:font-display prose-headings:font-bold prose-p:text-black">
          <Content />
        </div>
      </div>

      <!-- External Links -->
      {(vendor.data.website || vendor.data.instagram || vendor.data.facebook) && (
        <div class="bg-white rounded-xl shadow-md p-6 mb-8">
          <h2 class="font-display font-bold text-lg text-black mb-4">Find Them Online</h2>
          <div class="flex flex-wrap gap-4">
            {vendor.data.website && (
              <a
                href={vendor.data.website}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-cream px-4 py-2 rounded-md text-black hover:bg-orange/10 transition-colors"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                </svg>
                Website
              </a>
            )}
            {vendor.data.instagram && (
              <a
                href={vendor.data.instagram.startsWith('http') ? vendor.data.instagram : `https://instagram.com/${vendor.data.instagram.replace('@', '')}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-cream px-4 py-2 rounded-md text-black hover:bg-orange/10 transition-colors"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
                </svg>
                Instagram
              </a>
            )}
            {vendor.data.facebook && (
              <a
                href={vendor.data.facebook}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-cream px-4 py-2 rounded-md text-black hover:bg-orange/10 transition-colors"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
                </svg>
                Facebook
              </a>
            )}
          </div>
        </div>
      )}

      <!-- Recipes featuring this vendor -->
      {vendorRecipes.length > 0 && (
        <div class="bg-orange/10 rounded-2xl p-6 md:p-8 mb-8">
          <h2 class="font-display font-bold text-xl text-black mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
            Recipes Featuring {vendor.data.name}
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {vendorRecipes.map((recipe: any) => (
              <a
                href={`${base}/recipes/${recipe.data.slug}`}
                class="bg-white rounded-xl p-4 hover:shadow-md transition-shadow block"
              >
                <p class="font-display font-bold text-black">{recipe.data.title}</p>
                <p class="text-black text-sm mt-1">
                  {recipe.data.prepTime && `Prep: ${recipe.data.prepTime}`}
                  {recipe.data.cookTime && ` · Cook: ${recipe.data.cookTime}`}
                </p>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Related Vendors -->
      {relatedVendors.length > 0 && (
        <div class="mb-8">
          <h2 class="font-display font-bold text-xl text-black mb-4">More Vendors You'll Love</h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            {relatedVendors.map((rv: any) => (
              <a
                href={`${base}/vendors/${rv.data.slug}`}
                class="bg-white rounded-xl shadow-md p-5 hover:shadow-lg transition-shadow block"
              >
                <h3 class="font-display font-bold text-black mb-1">{rv.data.name}</h3>
                <p class="text-black text-sm font-medium mb-2">{rv.data.tagline}</p>
                <div class="flex flex-wrap gap-1">
                  {rv.data.categories.slice(0, 3).map((cat: string) => (
                    <span class="bg-cream text-black text-xs px-2 py-0.5 rounded-md">
                      {categoryLabels[cat] || cat}
                    </span>
                  ))}
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- CTA -->
      <div class="bg-gradient-to-r from-orange to-purple rounded-2xl p-8 text-center text-cream">
        <h2 class="font-display font-bold text-2xl mb-3">
          Visit the Market This Saturday
        </h2>
        <p class="text-cream/90 mb-5">
          Find {vendor.data.name} and all our vendors on the Village Green in Kinderhook, NY.
        </p>
        <a href={`${base}/visit`} class="inline-block bg-white text-black font-display font-bold px-6 py-3 rounded-md hover:bg-white/90 transition-colors">
          Plan Your Visit
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
