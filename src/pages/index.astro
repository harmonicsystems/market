---
import BaseLayout from '../layouts/BaseLayout.astro';
import StructuredData from '../components/StructuredData.astro';
import { Image } from 'astro:assets';
import MarketIcon from '../components/MarketIcon.astro';
import HeroCore from '../components/HeroCore.astro';
import welcomeImage from '../assets/images/decorative/welcome-kinderhook.webp';
import siteConfig from '../data/site-config.json';
import thisWeek from '../data/this-week.json';

// Calculate days until next market
function getNextMarketInfo() {
  const now = new Date();
  const dayOfWeek = now.getDay();
  const daysUntilSaturday = (6 - dayOfWeek + 7) % 7 || 7;

  const seasonStart = new Date(siteConfig.season.start);
  const seasonEnd = new Date(siteConfig.season.end);

  const nextSaturday = new Date(now);
  nextSaturday.setDate(now.getDate() + daysUntilSaturday);

  const inSeason = nextSaturday >= seasonStart && nextSaturday <= seasonEnd;

  return {
    daysUntil: daysUntilSaturday,
    inSeason,
    seasonStart: seasonStart.toLocaleDateString('en-US', { month: 'long', day: 'numeric' }),
  };
}

const marketInfo = getNextMarketInfo();
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Fresh Local Produce Every Saturday"
  description="Visit the Kinderhook Farmers Market every Saturday on the Village Green in Kinderhook, NY. Fresh local produce, artisan goods, baked goods, live music, and community events in the heart of the Hudson Valley. Columbia County's favorite outdoor market, May through October."
  canonicalPath="/"
>
  <StructuredData slot="head" type="event" data={{ date: thisWeek.date, theme: thisWeek.theme, music: thisWeek.music }} />
  <!-- Hero: Market-Forward Identity (mobile-first, fluid scaling) -->
  <section id="homepage-hero" class="bg-cream py-10 sm:py-14">
    <div class="max-w-xl mx-auto px-4 text-center">
      <HeroCore />

      <p class="text-white font-body max-w-xs sm:max-w-sm mx-auto mt-5 mb-5 text-[clamp(0.9rem,3vw,1rem)]">
        Fresh local produce, artisan goods, and live music in the heart of the Hudson Valley.
      </p>

      <!-- Follow for weekly updates — hearts inline with the text so they stay
           attached when text wraps on narrow viewports. socials always below. -->
      <div class="flex flex-col items-center justify-center gap-3">
        <p class="font-display font-bold text-black text-sm sm:text-lg md:text-xl uppercase tracking-wider md:tracking-widest text-center whitespace-nowrap">
          <span class="social-icon-mask inline-block w-4 h-4 sm:w-5 sm:h-5 md:w-6 md:h-6 align-middle mr-1.5 sm:mr-2" style={`background-color: #2E1F2F; -webkit-mask-image: url('${base}/icons/FM-HEART-ICON.png'); mask-image: url('${base}/icons/FM-HEART-ICON.png');`} aria-hidden="true"></span>
          Follow for Weekly Updates
          <span class="social-icon-mask inline-block w-4 h-4 sm:w-5 sm:h-5 md:w-6 md:h-6 align-middle ml-1.5 sm:ml-2" style={`background-color: #2E1F2F; -webkit-mask-image: url('${base}/icons/FM-HEART-ICON.png'); mask-image: url('${base}/icons/FM-HEART-ICON.png');`} aria-hidden="true"></span>
        </p>
        <div class="flex flex-wrap justify-center items-center gap-4">
          <a href={siteConfig.contact.facebook} target="_blank" rel="noopener noreferrer" aria-label="Follow us on Facebook" class="inline-flex items-center justify-center hover:opacity-80 transition-opacity">
            <span class="social-icon-mask block w-10 h-10 md:w-12 md:h-12" style={`background-color: #2E1F2F; -webkit-mask-image: url('${base}/icons/FM-FACEBOOK-ICON.png'); mask-image: url('${base}/icons/FM-FACEBOOK-ICON.png');`}></span>
          </a>
          <a href={siteConfig.contact.instagram} target="_blank" rel="noopener noreferrer" aria-label="Follow us on Instagram" class="inline-flex items-center justify-center hover:opacity-80 transition-opacity">
            <span class="social-icon-mask block w-10 h-10 md:w-12 md:h-12" style={`background-color: #2E1F2F; -webkit-mask-image: url('${base}/icons/FM-INSTAGRAM-ICON.png'); mask-image: url('${base}/icons/FM-INSTAGRAM-ICON.png');`}></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- THIS WEEK'S LINEUP - The Main Event -->
  <section class="bg-white pt-[15px] pb-8 md:pb-12">
    <!-- Purple "NEXT MARKET:" banner — full-bleed across the page -->
    <div class="bg-purple py-3 md:py-4 mb-6 md:mb-8">
      <p class="text-center font-logo font-bold text-white uppercase tracking-[0.08em] text-[clamp(1.875rem,8.5vw,3rem)] leading-none">Next Market:</p>
    </div>
    <div class="max-w-4xl mx-auto px-4">
      <!-- Header -->
      <div class="text-center mb-6">
        <h2 class="font-logo font-bold uppercase tracking-[0.08em] text-2xl md:text-3xl text-black mb-1">
          {(() => {
            const [day, ...rest] = thisWeek.displayDate.split(',');
            const date = rest.join(',').trim();
            return (
              <>
                <span class="block">{day},</span>
                <span class="block">{date}</span>
              </>
            );
          })()}
        </h2>
        <p class="text-orange font-display font-bold text-lg">{thisWeek.theme}</p>
        <p class="text-black mt-2">
          {siteConfig.schedule.startTime} – {siteConfig.schedule.endTime}
        </p>
        <p class="mt-1">
          <a
            href="https://www.google.com/maps/search/?api=1&query=Kinderhook+Village+Green+Kinderhook+NY+12106"
            target="_blank"
            rel="noopener noreferrer"
            class="text-black underline decoration-2 underline-offset-[6px] [text-decoration-skip-ink:auto] hover:text-orange transition-colors"
          >
            Village Green
          </a>
        </p>
        {marketInfo.inSeason && marketInfo.daysUntil <= 7 && (
          <p id="weather-widget" class="text-black text-sm mt-2">
            <span id="weather-temp">…</span> <span class="text-black">·</span> <span id="weather-desc">Loading forecast</span>
          </p>
        )}
      </div>

      <!-- Lineup Grid - Mobile Stacked, Desktop Side-by-Side -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">

        <!-- Music -->
        <div class="bg-gradient-to-br from-purple/10 to-purple/5 rounded-xl p-4 md:p-5 card-bordered">
          <div class="flex items-center gap-3 mb-3">
            <span class="social-icon-mask block w-12 h-12 shrink-0" style={`background-color: #5D3C54; -webkit-mask-image: url('${base}/icons/FM-MUSIC-ICON.png'); mask-image: url('${base}/icons/FM-MUSIC-ICON.png');`} aria-hidden="true"></span>
            <div>
              <p class="font-display font-bold text-purple text-lg md:text-xl uppercase tracking-widest">Live Music</p>
              {thisWeek.music ? (
                <p class="font-display font-bold text-lg text-black">{thisWeek.music.name}</p>
              ) : (
                <p class="font-display font-bold text-lg text-black italic">Lineup coming soon</p>
              )}
            </div>
          </div>
          {thisWeek.music && (
            <p class="text-black text-sm">{thisWeek.music.time}</p>
          )}
        </div>

        <!-- Special Events -->
        {thisWeek.specialEvents.length > 0 && (
          <div class="bg-gradient-to-br from-orange/10 to-orange/5 rounded-xl p-4 md:p-5 card-bordered">
            <div class="flex items-center gap-3 mb-3">
              <span class="social-icon-mask block w-12 h-12 shrink-0" style={`background-color: #B8860B; -webkit-mask-image: url('${base}/icons/FM-STAR-ICON.png'); mask-image: url('${base}/icons/FM-STAR-ICON.png');`} aria-hidden="true"></span>
              <div>
                <p class="font-display font-bold text-orange text-lg md:text-xl uppercase tracking-widest">Special Event</p>
                <p class="font-display font-bold text-lg text-black">{thisWeek.specialEvents[0].name}</p>
              </div>
            </div>
            <p class="text-black text-sm">{thisWeek.specialEvents[0].description}</p>
          </div>
        )}
      </div>

      <!-- Vendors Lists - Clean, Scannable -->
      <div class="mt-6 space-y-4">
        <!-- Guest Vendors -->
        <div class="bg-white rounded-xl p-4">
          <h3 class="font-display font-bold text-black text-lg md:text-xl uppercase tracking-widest mb-3 flex items-center gap-2">
            <span class="w-2 h-2 bg-orange rounded-full"></span>
            Guest Vendors
          </h3>
          {thisWeek.guestVendors.length > 0 ? (
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              {thisWeek.guestVendors.map((vendor: string) => (
                <li class="flex items-center gap-2 text-black">
                  <svg class="w-4 h-4 text-orange shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  <span class="font-medium">{vendor}</span>
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-black italic">Lineup coming soon.</p>
          )}
        </div>

        <!-- Regular Vendors -->
        <div class="bg-white rounded-xl p-4">
          <h3 class="font-display font-bold text-black text-lg md:text-xl uppercase tracking-widest mb-3 flex items-center gap-2">
            <span class="w-2 h-2 bg-orange rounded-full"></span>
            Weekly Vendors
          </h3>
          {thisWeek.regularVendors.length > 0 ? (
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              {thisWeek.regularVendors.map((vendor: string) => (
                <li class="flex items-center gap-2 text-black">
                  <svg class="w-4 h-4 text-orange shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  <span>{vendor}</span>
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-black italic">Lineup coming soon.</p>
          )}
        </div>

        <!-- Community Partners -->
        {thisWeek.communityPartners.length > 0 && (
          <div class="bg-white rounded-xl p-4">
            <h3 class="font-display font-bold text-black text-lg md:text-xl uppercase tracking-widest mb-3 flex items-center gap-2">
              <span class="w-2 h-2 bg-orange rounded-full"></span>
              Community Partners
            </h3>
            <ul class="flex flex-wrap gap-2">
              {thisWeek.communityPartners.map((partner: string) => (
                <li class="bg-white px-3 py-1 rounded-md text-sm text-black border border-orange/20">
                  {partner}
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>

      <!-- CTA — hidden for now
      <div class="mt-6 flex flex-col sm:flex-row gap-3 justify-center">
        <a href={`${base}/vendors`} class="inline-flex items-center justify-center gap-2 bg-orange text-white font-display font-bold px-6 py-3 rounded-md hover:bg-orange/90 transition-colors text-center">
          Meet All Vendors
        </a>
      </div>
      -->

    </div>
  </section>

  <!-- Weather Widget Script — Open-Meteo (free, no API key) -->
  <script>
    const WMO_CODES: Record<number, { desc: string; icon: string }> = {
      0: { desc: 'Clear skies', icon: '☀️' },
      1: { desc: 'Mostly clear', icon: '🌤️' },
      2: { desc: 'Partly cloudy', icon: '⛅' },
      3: { desc: 'Overcast', icon: '☁️' },
      45: { desc: 'Foggy', icon: '🌫️' },
      48: { desc: 'Foggy', icon: '🌫️' },
      51: { desc: 'Light drizzle', icon: '🌦️' },
      53: { desc: 'Drizzle', icon: '🌦️' },
      55: { desc: 'Heavy drizzle', icon: '🌧️' },
      61: { desc: 'Light rain', icon: '🌦️' },
      63: { desc: 'Rain', icon: '🌧️' },
      65: { desc: 'Heavy rain', icon: '🌧️' },
      71: { desc: 'Light snow', icon: '🌨️' },
      73: { desc: 'Snow', icon: '❄️' },
      75: { desc: 'Heavy snow', icon: '❄️' },
      80: { desc: 'Rain showers', icon: '🌦️' },
      81: { desc: 'Rain showers', icon: '🌧️' },
      82: { desc: 'Heavy showers', icon: '⛈️' },
      95: { desc: 'Thunderstorm', icon: '⛈️' },
      96: { desc: 'Thunderstorm', icon: '⛈️' },
      99: { desc: 'Severe storm', icon: '⛈️' },
    };

    async function loadWeather() {
      const tempEl = document.getElementById('weather-temp');
      const descEl = document.getElementById('weather-desc');
      if (!tempEl || !descEl) return;

      try {
        const res = await fetch(
          'https://api.open-meteo.com/v1/forecast?latitude=42.3951&longitude=-73.6981&daily=temperature_2m_max,temperature_2m_min,weathercode&temperature_unit=fahrenheit&timezone=America/New_York&forecast_days=7'
        );
        const data = await res.json();

        // Find the next Saturday (day 6 = Saturday)
        const today = new Date();
        const dates = data.daily.time as string[];
        let satIdx = -1;
        for (let i = 0; i < dates.length; i++) {
          const d = new Date(dates[i] + 'T12:00:00');
          if (d.getDay() === 6 && d >= today) {
            satIdx = i;
            break;
          }
        }

        // If today IS Saturday, use today
        if (satIdx === -1 && today.getDay() === 6) {
          satIdx = 0;
        }

        if (satIdx === -1) {
          descEl.textContent = 'Check back soon';
          tempEl.textContent = '—';
          return;
        }

        const high = Math.round(data.daily.temperature_2m_max[satIdx]);
        const low = Math.round(data.daily.temperature_2m_min[satIdx]);
        const code = data.daily.weathercode[satIdx];
        const weather = WMO_CODES[code] || { desc: 'Variable', icon: '🌤️' };

        tempEl.textContent = `${weather.icon} ${high}°F`;
        descEl.textContent = `${weather.desc} · Low ${low}°F`;
      } catch {
        tempEl.textContent = '—';
        descEl.textContent = 'Forecast unavailable';
      }
    }

    loadWeather();
  </script>
</BaseLayout>
