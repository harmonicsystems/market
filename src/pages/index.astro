---
import BaseLayout from '../layouts/BaseLayout.astro';
import StructuredData from '../components/StructuredData.astro';
import { Image } from 'astro:assets';
import ShareableMarketCard from '../components/ShareableMarketCard.astro';
import welcomeImage from '../assets/images/decorative/welcome-kinderhook.webp';
import siteConfig from '../data/site-config.json';
import thisWeek from '../data/this-week.json';

// Calculate days until next market
function getNextMarketInfo() {
  const now = new Date();
  const dayOfWeek = now.getDay();
  const daysUntilSaturday = (6 - dayOfWeek + 7) % 7 || 7;

  const seasonStart = new Date(siteConfig.season.start);
  const seasonEnd = new Date(siteConfig.season.end);

  const nextSaturday = new Date(now);
  nextSaturday.setDate(now.getDate() + daysUntilSaturday);

  const inSeason = nextSaturday >= seasonStart && nextSaturday <= seasonEnd;

  return {
    daysUntil: daysUntilSaturday,
    inSeason,
    seasonStart: seasonStart.toLocaleDateString('en-US', { month: 'long', day: 'numeric' }),
  };
}

const marketInfo = getNextMarketInfo();
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Fresh Local Produce Every Saturday"
  description="Visit the Kinderhook Farmers' Market every Saturday on the Village Green in Kinderhook, NY. Fresh local produce, artisan goods, baked goods, live music, and community events in the heart of the Hudson Valley. Columbia County's favorite outdoor market, May through October."
  canonicalPath="/"
>
  <StructuredData slot="head" type="event" data={{ date: thisWeek.date, theme: thisWeek.theme, music: thisWeek.music }} />
  <!-- Hero: Market-Forward Identity -->
  <section class="bg-cream py-14 md:py-24 hero-texture">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="mb-4">
        <span class="block font-display font-bold text-4xl md:text-6xl lg:text-7xl tracking-wide text-black uppercase">Kinderhook</span>
        <span class="block font-display font-bold text-2xl md:text-4xl lg:text-5xl text-orange tracking-[0.15em] uppercase mt-1">&mdash; Farmers' Market &mdash;</span>
      </h1>
      <hr class="gold-rule mb-8" />

      <!-- Essential Info — When / Where / Season / Weather -->
      <div class="bg-black text-white rounded-xl p-6 md:p-8 mb-8 max-w-3xl mx-auto">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
          <div>
            <p class="section-label mb-1" style="color: rgba(184,134,11,0.7);">When</p>
            <p class="font-display font-bold text-lg md:text-xl">Every Saturday</p>
            <p class="text-white/70 text-sm mt-1">8:30 AM &ndash; 12:30 PM</p>
          </div>
          <div class="sm:border-l sm:border-white/20">
            <p class="section-label mb-1" style="color: rgba(184,134,11,0.7);">Where</p>
            <p class="font-display font-bold text-lg md:text-xl">Village Green</p>
            <p class="text-white/70 text-sm mt-1">Kinderhook, NY</p>
          </div>
          <div class="sm:border-l sm:border-white/20">
            <p class="section-label mb-1" style="color: rgba(184,134,11,0.7);">Season</p>
            <p class="font-display font-bold text-lg md:text-xl">May &ndash; October</p>
            <p class="text-white/70 text-sm mt-1">Rain or Shine</p>
          </div>
          <div class="sm:border-l sm:border-white/20" id="weather-widget">
            <p class="section-label mb-1" style="color: rgba(184,134,11,0.7);">This Saturday</p>
            <p class="font-display font-bold text-lg md:text-xl" id="weather-temp">&hellip;</p>
            <p class="text-white/70 text-sm mt-1" id="weather-desc">Loading forecast</p>
          </div>
        </div>
      </div>

      <p class="text-lg md:text-xl text-black/60 font-body max-w-2xl mx-auto italic mb-6">
        Fresh local produce, artisan goods, and live music in the heart of the Hudson Valley.
      </p>
      <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm text-black/40">
        <span>Best of Columbia County 2019</span>
        <span>&middot;</span>
        <span>20+ years</span>
        <span>&middot;</span>
        <span>Volunteer-run</span>
      </div>
    </div>
  </section>

  <!-- THIS WEEK'S LINEUP - The Main Event -->
  <section class="bg-white py-8 md:py-12 border-y-4 border-orange">
    <div class="max-w-4xl mx-auto px-4">
      <!-- Header -->
      <div class="text-center mb-6">
        <div class="inline-flex items-center gap-2 bg-orange text-white px-4 py-2 rounded-md text-sm font-bold mb-3">
          <span class="animate-pulse w-2 h-2 bg-white rounded-full"></span>
          {thisWeek.note}
        </div>
        <h2 class="font-display font-bold text-2xl md:text-3xl text-black mb-1">
          {thisWeek.displayDate}
        </h2>
        <p class="text-teal font-display font-bold text-lg">{thisWeek.theme}</p>
        <p class="text-black/60 mt-2">
          {siteConfig.schedule.startTime} – {siteConfig.schedule.endTime} • Village Green
        </p>
      </div>

      <!-- Lineup Grid - Mobile Stacked, Desktop Side-by-Side -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">

        <!-- Music -->
        {thisWeek.music && (
          <div class="bg-gradient-to-br from-teal/10 to-teal/5 rounded-xl p-4 md:p-5 card-bordered">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 bg-teal rounded-full flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs text-teal font-semibold uppercase tracking-wide">Live Music</p>
                <p class="font-display font-bold text-lg text-black">{thisWeek.music.name}</p>
              </div>
            </div>
            <p class="text-black/70 text-sm ml-13">{thisWeek.music.time}</p>
          </div>
        )}

        <!-- Special Events -->
        {thisWeek.specialEvents.length > 0 && (
          <div class="bg-gradient-to-br from-orange/10 to-orange/5 rounded-xl p-4 md:p-5 card-bordered">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 bg-orange rounded-full flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                </svg>
              </div>
              <div>
                <p class="text-xs text-orange font-semibold uppercase tracking-wide">Special Event</p>
                <p class="font-display font-bold text-lg text-black">{thisWeek.specialEvents[0].name}</p>
              </div>
            </div>
            <p class="text-black/70 text-sm">{thisWeek.specialEvents[0].description}</p>
          </div>
        )}
      </div>

      <!-- Vendors Lists - Clean, Scannable -->
      <div class="mt-6 space-y-4">
        <!-- Guest Vendors -->
        {thisWeek.guestVendors.length > 0 && (
          <div class="bg-cream rounded-xl p-4">
            <h3 class="font-display font-bold text-sm text-orange uppercase tracking-wide mb-3 flex items-center gap-2">
              <span class="w-2 h-2 bg-orange rounded-full"></span>
              Guest Vendors This Week
            </h3>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              {thisWeek.guestVendors.map((vendor: string) => (
                <li class="flex items-center gap-2 text-black">
                  <svg class="w-4 h-4 text-orange shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  <span class="font-medium">{vendor}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Regular Vendors -->
        <div class="bg-lime/10 rounded-xl p-4">
          <h3 class="font-display font-bold text-sm text-lime uppercase tracking-wide mb-3 flex items-center gap-2">
            <span class="w-2 h-2 bg-lime rounded-full"></span>
            Weekly Vendors
          </h3>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            {thisWeek.regularVendors.map((vendor: string) => (
              <li class="flex items-center gap-2 text-black">
                <svg class="w-4 h-4 text-lime shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <span>{vendor}</span>
              </li>
            ))}
            <li class="flex items-center gap-2 text-black/60">
              <span class="ml-6">+ more weekly favorites</span>
            </li>
          </ul>
        </div>

        <!-- Community Partners -->
        {thisWeek.communityPartners.length > 0 && (
          <div class="bg-teal/10 rounded-xl p-4">
            <h3 class="font-display font-bold text-sm text-teal uppercase tracking-wide mb-3 flex items-center gap-2">
              <span class="w-2 h-2 bg-teal rounded-full"></span>
              Community Partners
            </h3>
            <ul class="flex flex-wrap gap-2">
              {thisWeek.communityPartners.map((partner: string) => (
                <li class="bg-white px-3 py-1 rounded-md text-sm text-black/80 border border-teal/20">
                  {partner}
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>

      <!-- CTA -->
      <div class="mt-6 flex flex-col sm:flex-row gap-3 justify-center">
        <a href={`${base}/vendors`} class="inline-flex items-center justify-center gap-2 bg-orange text-white font-display font-bold px-6 py-3 rounded-md hover:bg-orange/90 transition-colors text-center">
          Meet All Vendors
        </a>
        <a href={`${base}/visit`} class="inline-flex items-center justify-center gap-2 bg-teal text-white font-display font-bold px-6 py-3 rounded-md hover:bg-teal/90 transition-colors text-center">
          Get Directions
        </a>
      </div>
    </div>
  </section>

  <!-- Share Save the Date -->
  <section class="bg-cream py-10">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-display font-bold text-2xl text-black text-center mb-6">
        Spread the Word!
      </h2>
      <p class="text-center text-black/70 mb-6">
        Download and share this week's market info with friends and neighbors.
      </p>
      <ShareableMarketCard
        date={thisWeek.date}
        displayDate={thisWeek.displayDate}
        theme={thisWeek.theme}
        music={thisWeek.music}
      />
    </div>
  </section>

  <!-- What's in Season Preview -->
  <section class="bg-white py-10">
    <div class="max-w-4xl mx-auto px-4">
      <p class="section-label text-center mb-2">From Our Vendors</p>
      <h2 class="font-display font-bold text-2xl text-black text-center mb-2">
        Fresh This Season
      </h2>
      <hr class="gold-rule mb-6" />
      <div class="flex flex-wrap justify-center gap-3 mb-6">
        <span class="bg-cream px-4 py-2 rounded-md text-black font-medium card-bordered">Asparagus</span>
        <span class="bg-cream px-4 py-2 rounded-md text-black font-medium card-bordered">Rhubarb</span>
        <span class="bg-cream px-4 py-2 rounded-md text-black font-medium card-bordered">Spring Greens</span>
        <span class="bg-cream px-4 py-2 rounded-md text-black font-medium card-bordered">Radishes</span>
        <span class="bg-cream px-4 py-2 rounded-md text-black font-medium card-bordered">Strawberries</span>
        <span class="bg-cream px-4 py-2 rounded-md text-black font-medium card-bordered">Fresh Herbs</span>
      </div>
      <p class="text-center">
        <a href={`${base}/whats-fresh`} class="text-teal font-display font-semibold hover:underline">
          See full seasonal guide →
        </a>
      </p>
    </div>
  </section>

  <!-- History Callout - Compact -->
  <section class="bg-white py-10">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <span class="inline-block bg-black text-white font-accent text-xl px-4 py-2 rounded-md mb-4">
        It's OK!
      </span>
      <p class="text-black/70 leading-relaxed">
        Kinderhook was home to President Martin Van Buren, nicknamed "Old Kinderhook."
        His supporters' "OK Clubs" may have given us the word "okay"!
        <a href={`${base}/about`} class="text-teal font-semibold hover:underline ml-1">Learn more</a>
      </p>
    </div>
  </section>

  <!-- Social Follow -->
  <section class="bg-cream py-10">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-display font-bold text-xl text-black mb-4">
        Follow for Weekly Updates
      </h2>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href={siteConfig.contact.facebook}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-white px-5 py-3 rounded-md shadow-sm hover:shadow-md transition-shadow"
        >
          <svg class="w-5 h-5 text-[#1877F2]" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
          </svg>
          <span class="font-semibold text-black">Facebook</span>
        </a>
        <a
          href={siteConfig.contact.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-white px-5 py-3 rounded-md shadow-sm hover:shadow-md transition-shadow"
        >
          <svg class="w-5 h-5 text-[#E4405F]" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
          </svg>
          <span class="font-semibold text-black">Instagram</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Weather Widget Script — Open-Meteo (free, no API key) -->
  <script>
    const WMO_CODES: Record<number, { desc: string; icon: string }> = {
      0: { desc: 'Clear skies', icon: '☀️' },
      1: { desc: 'Mostly clear', icon: '🌤️' },
      2: { desc: 'Partly cloudy', icon: '⛅' },
      3: { desc: 'Overcast', icon: '☁️' },
      45: { desc: 'Foggy', icon: '🌫️' },
      48: { desc: 'Foggy', icon: '🌫️' },
      51: { desc: 'Light drizzle', icon: '🌦️' },
      53: { desc: 'Drizzle', icon: '🌦️' },
      55: { desc: 'Heavy drizzle', icon: '🌧️' },
      61: { desc: 'Light rain', icon: '🌦️' },
      63: { desc: 'Rain', icon: '🌧️' },
      65: { desc: 'Heavy rain', icon: '🌧️' },
      71: { desc: 'Light snow', icon: '🌨️' },
      73: { desc: 'Snow', icon: '❄️' },
      75: { desc: 'Heavy snow', icon: '❄️' },
      80: { desc: 'Rain showers', icon: '🌦️' },
      81: { desc: 'Rain showers', icon: '🌧️' },
      82: { desc: 'Heavy showers', icon: '⛈️' },
      95: { desc: 'Thunderstorm', icon: '⛈️' },
      96: { desc: 'Thunderstorm', icon: '⛈️' },
      99: { desc: 'Severe storm', icon: '⛈️' },
    };

    async function loadWeather() {
      const tempEl = document.getElementById('weather-temp');
      const descEl = document.getElementById('weather-desc');
      if (!tempEl || !descEl) return;

      try {
        const res = await fetch(
          'https://api.open-meteo.com/v1/forecast?latitude=42.3951&longitude=-73.6981&daily=temperature_2m_max,temperature_2m_min,weathercode&temperature_unit=fahrenheit&timezone=America/New_York&forecast_days=7'
        );
        const data = await res.json();

        // Find the next Saturday (day 6 = Saturday)
        const today = new Date();
        const dates = data.daily.time as string[];
        let satIdx = -1;
        for (let i = 0; i < dates.length; i++) {
          const d = new Date(dates[i] + 'T12:00:00');
          if (d.getDay() === 6 && d >= today) {
            satIdx = i;
            break;
          }
        }

        // If today IS Saturday, use today
        if (satIdx === -1 && today.getDay() === 6) {
          satIdx = 0;
        }

        if (satIdx === -1) {
          descEl.textContent = 'Check back soon';
          tempEl.textContent = '—';
          return;
        }

        const high = Math.round(data.daily.temperature_2m_max[satIdx]);
        const low = Math.round(data.daily.temperature_2m_min[satIdx]);
        const code = data.daily.weathercode[satIdx];
        const weather = WMO_CODES[code] || { desc: 'Variable', icon: '🌤️' };

        tempEl.textContent = `${weather.icon} ${high}°F`;
        descEl.textContent = `${weather.desc} · Low ${low}°F`;
      } catch {
        tempEl.textContent = '—';
        descEl.textContent = 'Forecast unavailable';
      }
    }

    loadWeather();
  </script>
</BaseLayout>
