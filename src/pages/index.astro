---
import BaseLayout from '../layouts/BaseLayout.astro';
import StructuredData from '../components/StructuredData.astro';
import { Image } from 'astro:assets';
import MarketIcon from '../components/MarketIcon.astro';
import HeroCore from '../components/HeroCore.astro';
import ShareableMarketCard from '../components/ShareableMarketCard.astro';
import { getCollection } from 'astro:content';
import welcomeImage from '../assets/images/decorative/welcome-kinderhook.webp';
import siteConfig from '../data/site-config.json';
import thisWeek from '../data/this-week.json';
import musicSchedule from '../data/music-schedule.json';
import weeklyVendors from '../data/weekly-vendors.json';

// Default to the season's weekly vendor roster; per-week override in this-week.json wins if present.
const usingRosterDefault = thisWeek.regularVendors.length === 0;
const regularVendorNames: string[] = usingRosterDefault
  ? weeklyVendors.vendors.map((v) => v.name)
  : thisWeek.regularVendors;

// Group the default roster by category so the homepage can render columns.
// Order preserved from weekly-vendors.json.
const weeklyCategoryOrder: string[] = [];
const weeklyByCategory: Record<string, string[]> = {};
if (usingRosterDefault) {
  for (const v of weeklyVendors.vendors) {
    const cat = v.category ?? 'Other';
    if (!weeklyByCategory[cat]) {
      weeklyByCategory[cat] = [];
      weeklyCategoryOrder.push(cat);
    }
    weeklyByCategory[cat].push(v.name);
  }
}

// Look up this week's performer from the season schedule; fall back to this-week.json override.
const scheduledMusic = musicSchedule.performances.find((p) => p.date === thisWeek.date);
const musicAct = scheduledMusic?.act ?? thisWeek.music?.name ?? null;
const musicTime = scheduledMusic ? musicSchedule.time : thisWeek.music?.time ?? null;

// Link the act name to /performers/[slug] when a profile exists.
const performerProfiles = await getCollection('performers');
const activePerformerSlugs = new Set(
  performerProfiles.filter((p) => p.data.active).map((p) => p.data.slug)
);
const musicHref =
  scheduledMusic?.performerSlug && activePerformerSlugs.has(scheduledMusic.performerSlug)
    ? `${import.meta.env.BASE_URL}/performers/${scheduledMusic.performerSlug}`
    : null;

// Calculate days until next market
function getNextMarketInfo() {
  const now = new Date();
  const dayOfWeek = now.getDay();
  const daysUntilSaturday = (6 - dayOfWeek + 7) % 7 || 7;

  const seasonStart = new Date(siteConfig.season.start);
  const seasonEnd = new Date(siteConfig.season.end);

  const nextSaturday = new Date(now);
  nextSaturday.setDate(now.getDate() + daysUntilSaturday);

  const inSeason = nextSaturday >= seasonStart && nextSaturday <= seasonEnd;

  return {
    daysUntil: daysUntilSaturday,
    inSeason,
    seasonStart: seasonStart.toLocaleDateString('en-US', { month: 'long', day: 'numeric' }),
  };
}

const marketInfo = getNextMarketInfo();
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Fresh Local Produce Every Saturday"
  description="Visit the Kinderhook Farmers Market every Saturday on the Village Green in Kinderhook, NY. Fresh local produce, artisan goods, baked goods, live music, and community events in the heart of the Hudson Valley. Columbia County's favorite outdoor market, May through October."
  canonicalPath="/"
>
  <StructuredData slot="head" type="event" data={{ date: thisWeek.date, theme: thisWeek.theme, music: thisWeek.music }} />
  <!-- Hero: Market-Forward Identity (mobile-first, fluid scaling) -->
  <section id="homepage-hero" class="bg-cream py-10 sm:py-14">
    <div class="max-w-xl mx-auto px-4 text-center">
      <HeroCore />

      <p class="text-black font-body max-w-xs sm:max-w-sm mx-auto mt-5 mb-5 text-[clamp(0.9rem,3vw,1rem)]">
        Fresh local produce, artisan goods, and live music in the heart of the Hudson Valley.
      </p>

      <!-- Follow for weekly updates — hearts inline with the text so they stay
           attached when text wraps on narrow viewports. socials always below. -->
      <div class="flex flex-col items-center justify-center gap-3">
        <p class="font-display font-bold text-black text-sm sm:text-lg md:text-xl uppercase tracking-wider md:tracking-widest text-center whitespace-nowrap">
          <span class="social-icon-mask inline-block w-4 h-4 sm:w-5 sm:h-5 md:w-6 md:h-6 align-middle mr-1.5 sm:mr-2" style={`background-color: #2E1F2F; -webkit-mask-image: url('${base}/icons/FM-HEART-ICON.png'); mask-image: url('${base}/icons/FM-HEART-ICON.png');`} aria-hidden="true"></span>
          Follow for Weekly Updates
          <span class="social-icon-mask inline-block w-4 h-4 sm:w-5 sm:h-5 md:w-6 md:h-6 align-middle ml-1.5 sm:ml-2" style={`background-color: #2E1F2F; -webkit-mask-image: url('${base}/icons/FM-HEART-ICON.png'); mask-image: url('${base}/icons/FM-HEART-ICON.png');`} aria-hidden="true"></span>
        </p>
        <div class="flex flex-wrap justify-center items-center gap-4">
          <a href={siteConfig.contact.facebook} target="_blank" rel="noopener noreferrer" aria-label="Follow us on Facebook" class="inline-flex items-center justify-center hover:opacity-80 transition-opacity">
            <span class="social-icon-mask block w-10 h-10 md:w-12 md:h-12" style={`background-color: #2E1F2F; -webkit-mask-image: url('${base}/icons/FM-FACEBOOK-ICON.png'); mask-image: url('${base}/icons/FM-FACEBOOK-ICON.png');`}></span>
          </a>
          <a href={siteConfig.contact.instagram} target="_blank" rel="noopener noreferrer" aria-label="Follow us on Instagram" class="inline-flex items-center justify-center hover:opacity-80 transition-opacity">
            <span class="social-icon-mask block w-10 h-10 md:w-12 md:h-12" style={`background-color: #2E1F2F; -webkit-mask-image: url('${base}/icons/FM-INSTAGRAM-ICON.png'); mask-image: url('${base}/icons/FM-INSTAGRAM-ICON.png');`}></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- THIS WEEK'S LINEUP - The Main Event -->
  <section class="bg-cream pt-[15px] pb-8 md:pb-12">
    <!-- Purple "NEXT MARKET:" banner — full-bleed across the page -->
    <div class="bg-purple py-3 md:py-4 mb-6 md:mb-8">
      <p class="text-center font-logo font-bold text-cream uppercase tracking-[0.08em] text-[clamp(1.875rem,8.5vw,3rem)] leading-none">Next Market:</p>
    </div>
    <div class="max-w-2xl mx-auto px-4">
      <!-- Primary info — the core screenshot-worthy block. Sized larger than
           default body content so a phone screenshot reads at a glance. -->
      <div class="text-center mb-10">
        <h2 class="font-logo font-bold uppercase tracking-[0.08em] text-3xl md:text-5xl text-black mb-2 leading-[1.05]">
          {(() => {
            const [day, ...rest] = thisWeek.displayDate.split(',');
            const date = rest.join(',').trim();
            return (
              <>
                <span class="block">{day},</span>
                <span class="block">{date}</span>
              </>
            );
          })()}
        </h2>
        {thisWeek.theme && (
          <p class="text-black font-display font-bold italic text-xl md:text-2xl mt-3">{thisWeek.theme}</p>
        )}
        <p class="text-black font-display text-xl md:text-2xl mt-5">
          {siteConfig.schedule.startTime} – {siteConfig.schedule.endTime}
        </p>
        <p class="mt-2">
          <a
            href="https://www.google.com/maps/search/?api=1&query=Kinderhook+Village+Green+Kinderhook+NY+12106"
            target="_blank"
            rel="noopener noreferrer"
            class="text-black font-display text-lg md:text-xl underline decoration-2 underline-offset-[6px] [text-decoration-skip-ink:auto] hover:text-orange transition-colors"
          >
            Village Green
          </a>
        </p>
        {marketInfo.inSeason && marketInfo.daysUntil <= 7 && (
          <div class="mt-4">
            <p id="weather-widget" class="text-black/70 text-base">
              <span id="weather-temp">…</span> <span class="text-black/70">·</span> <span id="weather-desc">Loading forecast</span>
            </p>
            <p id="weather-updated" class="text-black/50 text-xs italic mt-1"></p>
          </div>
        )}
      </div>

      <!-- Music + Special Event — flat typographic rows, flanked by rules
           so the section reads as a single shareable info block. -->
      <div class="border-t border-b border-black/15 divide-y divide-black/10">
        <!-- Live Music -->
        <div class="py-7 flex items-center gap-5">
          <span
            class="social-icon-mask block w-14 h-14 md:w-16 md:h-16 shrink-0"
            style={`background-color: #2E1F2F; -webkit-mask-image: url('${base}/icons/FM-MUSIC-ICON.png'); mask-image: url('${base}/icons/FM-MUSIC-ICON.png');`}
            aria-hidden="true"
          ></span>
          <div class="flex-1">
            <p class="font-display font-bold text-black text-base uppercase tracking-widest">Live Music</p>
            {musicAct ? (
              <p class="font-display font-bold text-2xl md:text-3xl text-black leading-tight">
                {musicHref ? (
                  <a href={musicHref} class="hover:text-orange transition-colors underline decoration-2 underline-offset-4 [text-decoration-skip-ink:auto]">
                    {musicAct}
                  </a>
                ) : musicAct}
              </p>
            ) : (
              <p class="font-display font-bold text-xl text-black italic">Lineup coming soon</p>
            )}
            {musicTime && (
              <p class="text-black text-base mt-1">{musicTime}</p>
            )}
          </div>
        </div>

        {thisWeek.specialEvents.length > 0 && (
          <div class="py-7 flex items-center gap-5">
            <span
              class="social-icon-mask block w-14 h-14 md:w-16 md:h-16 shrink-0"
              style={`background-color: #B8860B; -webkit-mask-image: url('${base}/icons/FM-STAR-ICON.png'); mask-image: url('${base}/icons/FM-STAR-ICON.png');`}
              aria-hidden="true"
            ></span>
            <div class="flex-1">
              <p class="font-display font-bold text-orange text-base uppercase tracking-widest">Special Event</p>
              <p class="font-display font-bold text-2xl md:text-3xl text-black leading-tight">{thisWeek.specialEvents[0].name}</p>
              {thisWeek.specialEvents[0].time && (
                <p class="text-black text-base mt-1">{thisWeek.specialEvents[0].time}</p>
              )}
              {thisWeek.specialEvents[0].description && (
                <p class="text-black text-base mt-1">{thisWeek.specialEvents[0].description}</p>
              )}
            </div>
          </div>
        )}
      </div>

      <!-- Share the market — brought up from the footer so it's inline with
           the Next Market info. Gives people a clear hand-off to social right
           where the shareable content lives. -->
      <div class="my-8 md:my-10 text-center">
        <ShareableMarketCard
          date={thisWeek.date}
          displayDate={thisWeek.displayDate}
          theme={thisWeek.theme}
          music={thisWeek.music}
          tone="dark"
        />
      </div>

      <!-- Weekly Vendors — categorized columns (default season roster) or
           flat list (per-week override from this-week.json). -->
      <div>
        <h3 class="font-display font-bold text-black text-lg md:text-xl uppercase tracking-widest mb-4 flex items-center gap-2">
          <span class="w-2 h-2 bg-orange rounded-full"></span>
          Weekly Vendors
        </h3>
        {regularVendorNames.length === 0 ? (
          <p class="text-black italic">Lineup coming soon.</p>
        ) : usingRosterDefault ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-5">
            {weeklyCategoryOrder.map((cat) => (
              <div>
                <p class="font-logo uppercase tracking-[0.08em] text-xs text-black/60 mb-2 pb-1 border-b border-black/10">{cat}</p>
                <ul class="space-y-1">
                  {weeklyByCategory[cat].map((name) => (
                    <li class="text-black">{name}</li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        ) : (
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1">
            {regularVendorNames.map((vendor: string) => (
              <li class="text-black">{vendor}</li>
            ))}
          </ul>
        )}
      </div>

      <!-- Guest Vendors -->
      <div class="mt-8">
        <h3 class="font-display font-bold text-black text-lg md:text-xl uppercase tracking-widest mb-3 flex items-center gap-2">
          <span class="w-2 h-2 bg-orange rounded-full"></span>
          Guest Vendors
        </h3>
        {thisWeek.guestVendors.length > 0 ? (
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1">
            {thisWeek.guestVendors.map((vendor: string) => (
              <li class="text-black font-medium">{vendor}</li>
            ))}
          </ul>
        ) : (
          <p class="text-black italic">Lineup coming soon.</p>
        )}
      </div>

      <!-- Community Partners -->
      {thisWeek.communityPartners.length > 0 && (
        <div class="mt-8">
          <h3 class="font-display font-bold text-black text-lg md:text-xl uppercase tracking-widest mb-3 flex items-center gap-2">
            <span class="w-2 h-2 bg-orange rounded-full"></span>
            Community Partners
          </h3>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1">
            {thisWeek.communityPartners.map((partner: string) => (
              <li class="text-black">{partner}</li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </section>

  <!-- Weather Widget Script — Open-Meteo (free, no API key) -->
  <script>
    const WMO_CODES: Record<number, { desc: string; icon: string }> = {
      0: { desc: 'Clear skies', icon: '☀️' },
      1: { desc: 'Mostly clear', icon: '🌤️' },
      2: { desc: 'Partly cloudy', icon: '⛅' },
      3: { desc: 'Overcast', icon: '☁️' },
      45: { desc: 'Foggy', icon: '🌫️' },
      48: { desc: 'Foggy', icon: '🌫️' },
      51: { desc: 'Light drizzle', icon: '🌦️' },
      53: { desc: 'Drizzle', icon: '🌦️' },
      55: { desc: 'Heavy drizzle', icon: '🌧️' },
      61: { desc: 'Light rain', icon: '🌦️' },
      63: { desc: 'Rain', icon: '🌧️' },
      65: { desc: 'Heavy rain', icon: '🌧️' },
      71: { desc: 'Light snow', icon: '🌨️' },
      73: { desc: 'Snow', icon: '❄️' },
      75: { desc: 'Heavy snow', icon: '❄️' },
      80: { desc: 'Rain showers', icon: '🌦️' },
      81: { desc: 'Rain showers', icon: '🌧️' },
      82: { desc: 'Heavy showers', icon: '⛈️' },
      95: { desc: 'Thunderstorm', icon: '⛈️' },
      96: { desc: 'Thunderstorm', icon: '⛈️' },
      99: { desc: 'Severe storm', icon: '⛈️' },
    };

    async function loadWeather() {
      const tempEl = document.getElementById('weather-temp');
      const descEl = document.getElementById('weather-desc');
      const updatedEl = document.getElementById('weather-updated');
      if (!tempEl || !descEl) return;

      function stampTimestamp() {
        if (!updatedEl) return;
        const now = new Date().toLocaleString('en-US', {
          weekday: 'short',
          month: 'short',
          day: 'numeric',
          hour: 'numeric',
          minute: '2-digit',
          timeZone: 'America/New_York',
        });
        updatedEl.textContent = `Forecast last updated ${now}`;
      }

      try {
        const res = await fetch(
          'https://api.open-meteo.com/v1/forecast?latitude=42.3951&longitude=-73.6981&daily=temperature_2m_max,temperature_2m_min,weathercode&temperature_unit=fahrenheit&timezone=America/New_York&forecast_days=7'
        );
        const data = await res.json();

        // Find the next Saturday (day 6 = Saturday)
        const today = new Date();
        const dates = data.daily.time as string[];
        let satIdx = -1;
        for (let i = 0; i < dates.length; i++) {
          const d = new Date(dates[i] + 'T12:00:00');
          if (d.getDay() === 6 && d >= today) {
            satIdx = i;
            break;
          }
        }

        // If today IS Saturday, use today
        if (satIdx === -1 && today.getDay() === 6) {
          satIdx = 0;
        }

        if (satIdx === -1) {
          descEl.textContent = 'Check back soon';
          tempEl.textContent = '—';
          return;
        }

        const high = Math.round(data.daily.temperature_2m_max[satIdx]);
        const low = Math.round(data.daily.temperature_2m_min[satIdx]);
        const code = data.daily.weathercode[satIdx];
        const weather = WMO_CODES[code] || { desc: 'Variable', icon: '🌤️' };

        tempEl.textContent = `${weather.icon} ${high}°F`;
        descEl.textContent = `${weather.desc} · Low ${low}°F`;
        stampTimestamp();
      } catch {
        tempEl.textContent = '—';
        descEl.textContent = 'Forecast unavailable';
      }
    }

    loadWeather();
  </script>
</BaseLayout>
