---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StructuredData from '../../components/StructuredData.astro';
import { getCollection, render } from 'astro:content';

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const landmarks = await getCollection('landmarks');
  return landmarks.map((landmark) => ({
    params: { slug: landmark.data.slug },
    props: { landmark },
  }));
}

const { landmark } = Astro.props;
const { Content } = await render(landmark);

const typeLabels: Record<string, string> = {
  'historic-site': 'Historic Site',
  'museum': 'Museum',
  'gallery': 'Gallery',
  'trail': 'Trail',
  'neighborhood': 'Neighborhood',
};
---

<BaseLayout
  title={landmark.data.name}
  description={`${landmark.data.name} — ${landmark.data.tagline || 'a landmark'} in Kinderhook, NY. ${landmark.data.description || ''} Plan your visit to this Columbia County attraction in the Hudson Valley.`}
  canonicalPath={`/discover/${landmark.data.slug}`}
>
  <StructuredData slot="head" type="landmark" data={landmark.data} />
  <StructuredData slot="head" type="breadcrumb" data={{ items: [
    { name: 'Home', url: '/' },
    { name: 'Discover Kinderhook', url: '/discover' },
    { name: landmark.data.name, url: `/discover/${landmark.data.slug}` },
  ] }} />

  <article class="bg-cream py-12">
    <div class="max-w-3xl mx-auto px-4">
      <!-- Back link -->
      <a href={`${base}/discover`} class="inline-flex items-center gap-2 text-orange font-semibold hover:underline mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Discover Kinderhook
      </a>

      <!-- Header -->
      <header class="mb-8">
        <span class="inline-block bg-orange/10 text-orange text-sm font-medium px-3 py-1 rounded-md mb-4">
          {typeLabels[landmark.data.type] || landmark.data.type}
        </span>
        <h1 class="font-display font-bold text-3xl md:text-4xl text-black mb-2">
          {landmark.data.name}
        </h1>
        {landmark.data.tagline && (
          <p class="text-purple font-display font-semibold text-lg">{landmark.data.tagline}</p>
        )}
      </header>

      <!-- Content -->
      <div class="bg-white rounded-xl shadow-md p-6 md:p-8 mb-8">
        <div class="prose prose-lg max-w-none prose-headings:font-display prose-headings:font-bold prose-p:text-black">
          <Content />
        </div>
      </div>

      <!-- Visitor Info -->
      {(landmark.data.address || landmark.data.hours || landmark.data.phone || landmark.data.website || landmark.data.admission) && (
        <div class="bg-white rounded-xl shadow-md p-6 mb-8">
          <h2 class="font-display font-bold text-lg text-black mb-4">Visitor Information</h2>
          <div class="space-y-3">
            {landmark.data.address && (
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-orange mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <div>
                  <p class="text-black">{landmark.data.address}</p>
                  {landmark.data.coordinates && (
                    <a
                      href={`https://www.google.com/maps/search/?api=1&query=${landmark.data.coordinates.lat},${landmark.data.coordinates.lng}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-orange text-sm font-semibold hover:underline"
                    >
                      Get Directions
                    </a>
                  )}
                </div>
              </div>
            )}
            {landmark.data.hours && (
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-orange mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span class="text-black">{landmark.data.hours}</span>
              </div>
            )}
            {landmark.data.phone && (
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-orange mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                <a href={`tel:${landmark.data.phone}`} class="text-orange hover:underline">{landmark.data.phone}</a>
              </div>
            )}
            {landmark.data.website && (
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-orange mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                </svg>
                <a href={landmark.data.website} target="_blank" rel="noopener noreferrer" class="text-orange hover:underline">Official Website</a>
              </div>
            )}
            {landmark.data.admission && (
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-orange mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
                </svg>
                <span class="text-black">Admission: <strong>{landmark.data.admission}</strong></span>
              </div>
            )}
          </div>
        </div>
      )}

      <!-- CTA -->
      <div class="bg-gradient-to-r from-orange to-purple rounded-2xl p-8 text-center text-white">
        <h2 class="font-display font-bold text-2xl mb-3">
          Make a Day of It
        </h2>
        <p class="text-white/90 mb-5">
          Combine your visit with a Saturday morning at the Kinderhook Farmers Market, just minutes away on the Village Green.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href={`${base}/visit`} class="inline-block bg-white text-black font-display font-bold px-6 py-3 rounded-md hover:bg-white/90 transition-colors">
            Plan Your Visit
          </a>
          <a href={`${base}/discover`} class="inline-block bg-white/20 text-white font-display font-bold px-6 py-3 rounded-md hover:bg-white/30 transition-colors">
            More to Discover
          </a>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
