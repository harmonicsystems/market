---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StructuredData from '../../components/StructuredData.astro';
import MarketIcon from '../../components/MarketIcon.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const allLandmarks = await getCollection('landmarks');

const typeLabels: Record<string, string> = {
  'historic-site': 'Historic Sites',
  'museum': 'Museums & Archives',
  'gallery': 'Galleries',
  'trail': 'Trails & Outdoor',
  'neighborhood': 'Neighborhoods',
};

const typeIcons: Record<string, string> = {
  'historic-site': 'history',
  'museum': 'history',
  'gallery': 'brush',
  'trail': 'bird',
  'neighborhood': 'bike',
};

// Group landmarks by type, ordered
const typeOrder = ['historic-site', 'gallery', 'museum', 'trail', 'neighborhood'];
const grouped = typeOrder
  .map(t => ({ type: t, landmarks: allLandmarks.filter(l => l.data.type === t) }))
  .filter(g => g.landmarks.length > 0);

const featured = allLandmarks.filter(l => l.data.featured);
---

<BaseLayout
  title="Discover Kinderhook"
  description="Things to do in Kinderhook, NY — historic sites, world-class art galleries, scenic trails, and charming village shops in the heart of Columbia County. Plan your Hudson Valley day trip to one of New York's most historic villages."
  canonicalPath="/discover"
>
  <StructuredData slot="head" type="breadcrumb" data={{ items: [{ name: 'Home', url: '/' }, { name: 'Discover Kinderhook', url: '/discover' }] }} />

  <!-- Hero -->
  <section class="bg-cream py-12">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <span class="inline-block bg-black text-white font-accent text-lg px-4 py-1 rounded-md mb-4">It's OK!</span>
        <h1 class="font-display font-bold text-4xl md:text-5xl text-black mb-4">
          Discover Kinderhook
        </h1>
        <p class="text-black/90 text-lg max-w-3xl mx-auto">
          One of the Hudson Valley's most historic villages, Kinderhook is the birthplace of President Martin Van Buren, home to world-class art, centuries-old Dutch Colonial landmarks, and a vibrant community on the Village Green. A perfect Columbia County day trip.
        </p>
      </div>

      <!-- Featured highlights -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
        {featured.map((landmark) => (
          <article class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition-shadow">
            <a href={`${base}/discover/${landmark.data.slug}`} class="block">
              <div class={`h-40 bg-gradient-to-br ${
                landmark.data.type === 'historic-site' ? 'from-orange/15 to-teal/15' :
                landmark.data.type === 'gallery' ? 'from-teal/15 to-lime/15' :
                landmark.data.type === 'trail' ? 'from-lime/15 to-teal/15' :
                'from-teal/15 to-orange/15'
              } flex items-center justify-center`}>
                <span class="opacity-40"><MarketIcon name={typeIcons[landmark.data.type] || 'ok'} class="w-14 h-14" /></span>
              </div>
            </a>
            <div class="p-5">
              <span class="inline-block bg-teal/10 text-teal text-xs font-medium px-2 py-1 rounded-md mb-2">
                {typeLabels[landmark.data.type]?.replace(/s$/, '') || landmark.data.type}
              </span>
              <h2 class="font-display font-bold text-lg text-black mb-1">
                <a href={`${base}/discover/${landmark.data.slug}`} class="hover:text-orange transition-colors">
                  {landmark.data.name}
                </a>
              </h2>
              {landmark.data.tagline && (
                <p class="text-teal text-sm font-medium mb-2">{landmark.data.tagline}</p>
              )}
              <p class="text-black/70 text-sm line-clamp-3">{landmark.data.description}</p>
              {landmark.data.admission === 'Free' && (
                <span class="inline-block mt-3 bg-lime/20 text-lime text-xs font-bold px-2 py-1 rounded-md">
                  Free Admission
                </span>
              )}
            </div>
          </article>
        ))}
      </div>

      <!-- All landmarks by type -->
      {grouped.map(({ type, landmarks }) => (
        <div class="mb-12">
          <h2 class="font-display font-bold text-2xl text-black mb-6 flex items-center gap-3">
            <span class="opacity-70"><MarketIcon name={typeIcons[type]} class="w-8 h-8" /></span>
            {typeLabels[type]}
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {landmarks.map((landmark) => (
              <a
                href={`${base}/discover/${landmark.data.slug}`}
                class="bg-white rounded-xl shadow-sm p-5 hover:shadow-md transition-shadow block"
              >
                <h3 class="font-display font-bold text-black mb-1">{landmark.data.name}</h3>
                {landmark.data.tagline && (
                  <p class="text-teal text-sm font-medium mb-2">{landmark.data.tagline}</p>
                )}
                <p class="text-black/60 text-sm">{landmark.data.description}</p>
                <div class="flex flex-wrap gap-3 mt-3 text-xs text-black/50">
                  {landmark.data.hours && (
                    <span class="flex items-center gap-1">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      {landmark.data.hours}
                    </span>
                  )}
                  {landmark.data.admission === 'Free' && (
                    <span class="bg-lime/20 text-lime font-bold px-2 py-0.5 rounded-md">Free</span>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}

      <!-- Trip planning CTA -->
      <div class="bg-gradient-to-r from-orange to-teal rounded-2xl p-8 text-center text-white">
        <h2 class="font-display font-bold text-2xl mb-3">
          Plan Your Kinderhook Day Trip
        </h2>
        <p class="text-white/90 mb-5 max-w-xl mx-auto">
          Start with the Saturday farmers' market on the Village Green, explore historic sites and galleries, then enjoy lunch at a local restaurant. It's all walkable.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href={`${base}/visit`} class="inline-block bg-white text-black font-display font-bold px-6 py-3 rounded-md hover:bg-white/90 transition-colors">
            Plan Your Visit
          </a>
          <a href={`${base}/businesses`} class="inline-block bg-white/20 text-white font-display font-bold px-6 py-3 rounded-md hover:bg-white/30 transition-colors">
            Local Businesses
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
