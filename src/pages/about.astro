---
import BaseLayout from '../layouts/BaseLayout.astro';
import StructuredData from '../components/StructuredData.astro';
import MarketIcon from '../components/MarketIcon.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const businesses = await getCollection('businesses');
const sortedBusinesses = businesses.sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<BaseLayout
  title="About"
  description="Learn about the Kinderhook Farmers Market, one of the oldest farmers markets in Columbia County, NY. Over 20 years of bringing fresh local food and community to the Hudson Valley. Discover the history of Kinderhook, birthplace of President Martin Van Buren and the word 'OK'."
  canonicalPath="/about"
>
  <StructuredData slot="head" type="breadcrumb" data={{ items: [{ name: 'Home', url: '/' }, { name: 'About', url: '/about' }] }} />
  <!-- Hero -->
  <section class="bg-cream py-10">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="font-display font-bold text-4xl md:text-5xl text-black mb-4">
        About the Market
      </h1>
      <p class="text-black text-lg">
        One of the oldest farmers markets in Columbia County, serving our community for over two decades.
      </p>
    </div>
  </section>

  <!-- Accolades — matches the NEXT MARKET purple banner pattern -->
  <section class="bg-purple text-cream py-6">
    <div class="max-w-4xl mx-auto px-4">
      <div class="flex flex-wrap justify-center items-center gap-6 text-center">
        <div class="flex items-center gap-2">
          <span
            class="social-icon-mask block w-7 h-7 shrink-0"
            style={`background-color: #f4f2d9; -webkit-mask-image: url('${base}/icons/FM-STAR-ICON.png'); mask-image: url('${base}/icons/FM-STAR-ICON.png');`}
            aria-hidden="true"
          ></span>
          <span class="font-display font-bold">Best Farmers Market 2019</span>
        </div>
        <div class="flex items-center gap-2">
          <span
            class="social-icon-mask block w-7 h-7 shrink-0"
            style={`background-color: #f4f2d9; -webkit-mask-image: url('${base}/icons/FM-STAR-ICON.png'); mask-image: url('${base}/icons/FM-STAR-ICON.png');`}
            aria-hidden="true"
          ></span>
          <span class="font-display font-bold">Finalist 2022</span>
        </div>
        <div class="text-cream/80 text-sm">Best of Columbia County</div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-white py-10">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <p class="font-display font-bold text-4xl text-orange">20+</p>
          <p class="text-black text-sm">Years Running</p>
        </div>
        <div>
          <p class="font-display font-bold text-4xl text-orange">10,000+</p>
          <p class="text-black text-sm">Visitors per Season</p>
        </div>
        <div>
          <p class="font-display font-bold text-4xl text-orange">50</p>
          <p class="text-black text-sm">Mile Vendor Radius</p>
        </div>
        <div>
          <p class="font-display font-bold text-4xl text-orange">100%</p>
          <p class="text-black text-sm">Volunteer-Run</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="bg-cream py-12">
    <div class="max-w-4xl mx-auto px-4">
      <!-- Our Story -->
      <div class="bg-white rounded-xl shadow-md p-6 md:p-8 mb-8">
        <h2 class="font-display font-bold text-2xl text-black mb-4">Our Story</h2>
        <p class="text-black mb-4">
          The Kinderhook Farmers Market is a welcoming space where individuals and families meet and participate in community events while accessing fresh local food, handmade goods, and more. It is one of the oldest farmers markets in Columbia County, operating in Kinderhook's historic Village Square for more than two decades.
        </p>
        <p class="text-black mb-4">
          Over the years, the market has played a key role in strengthening the local agricultural economy by providing an affordable outlet for small family farmers and food producers to expand their customer base. Vendors come from within a 50-mile radius of Kinderhook, and one of the hallmarks of the market is the commitment of our family of farmers to environmentally responsible farming practices.
        </p>
        <p class="text-black">
          The market also plays a central role in the village's overall economy by providing a seasonal destination for both residents and visitors. Market goers are invited to discover not only what market vendors have to offer but also the goods and services of the village's shops, galleries, recreational sites, and historic assets.
        </p>
      </div>

      <!-- Volunteer-Run -->
      <div class="bg-white rounded-xl shadow-md p-6 md:p-8 mb-8">
        <div class="flex items-start gap-4">
          <MarketIcon name="heart" class="w-12 h-12" />
          <div>
            <h3 class="font-display font-bold text-xl text-black mb-2">Organized by Volunteers</h3>
            <p class="text-black">
              The Kinderhook Farmers Market is organized and managed entirely by volunteers who dedicate their time to making Saturday mornings special for our community. Rain or shine, our volunteers are there to welcome visitors, support vendors, and keep the market running smoothly.
            </p>
          </div>
        </div>
      </div>

      <!-- Community Partners / Nonprofits -->
      <div class="bg-white rounded-xl shadow-md p-6 md:p-8 mb-8">
        <h2 class="font-display font-bold text-2xl text-black mb-4">Supporting Our Community</h2>
        <p class="text-black mb-4">
          In an ongoing commitment to local nonprofit organizations, the market provides free space for organizations to do public outreach. Among those nonprofits are local and regional organizations that advocate for:
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-5 mb-6">
          {[
            { heading: 'Food & Environment', items: ['Food sustainability', 'Environmental sustainability', 'Healthy food & nutrition'] },
            { heading: 'Nature & Animals',   items: ['Wildlife conservation', 'Animal welfare'] },
            { heading: 'Community Care',     items: ['Emergency response', 'Foster-care advocacy'] },
            { heading: 'Arts & Education',   items: ['The arts', 'History & literacy education'] },
          ].map(group => (
            <div>
              <h3 class="font-display font-bold text-sm text-black uppercase tracking-wide mb-2">{group.heading}</h3>
              <ul class="space-y-1 text-sm text-black">
                {group.items.map(item => (
                  <li class="flex items-start gap-2">
                    <span class="text-black mt-[0.1rem]">•</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
        <div class="bg-cream/40 p-4">
          <p class="text-black">
            <strong class="text-orange">
              <a href="https://valatiefoodpantry.com/" class="gold-link" rel="noopener" target="_blank">Valatie Ecumenical Food Pantry</a>:
            </strong>
            The market is especially proud to host a twice-monthly food-donation table that benefits the Valatie Food Pantry in their mission to provide essential assistance to nearly <strong>500 individuals and families</strong> experiencing food insecurity throughout Columbia County.
          </p>
        </div>
      </div>

      <!-- Sponsor -->
      <div class="bg-white rounded-xl shadow-md p-6 md:p-8 mb-8">
        <h2 class="font-display font-bold text-2xl text-black mb-4">Our Sponsor</h2>
        <p class="text-black mb-4">
          The Kinderhook Farmers Market is a project of the <strong>Kinderhook Business and Professional Association (KBPA)</strong>. The KBPA works to support local businesses, promote economic development, and enhance the quality of life in our community.
        </p>
        <p class="text-black">
          Through events like the farmers' market, the KBPA brings residents and visitors together while supporting the local economy and celebrating everything that makes Kinderhook special.
        </p>
      </div>

      <!-- KBPA Members -->
      <div class="bg-white rounded-xl shadow-md p-6 md:p-8">
        <h2 class="font-display font-bold text-2xl text-black mb-4">KBPA Members</h2>
        <p class="text-black mb-6">
          These local businesses and organizations make up the Kinderhook Business and Professional Association — the backbone of our village economy.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {sortedBusinesses.map((biz) => (
            <a
              href={`${base}/businesses/${biz.data.slug}`}
              class="flex items-center gap-3 p-3 rounded-xl hover:bg-cream transition-colors"
            >
              <MarketIcon name="ok" class="w-8 h-8" />
              <div>
                <p class="font-display font-semibold text-black text-sm">{biz.data.name}</p>
                {biz.data.tagline && <p class="text-black text-xs">{biz.data.tagline}</p>}
              </div>
            </a>
          ))}
        </div>
        <div class="mt-6 text-center">
          <a href={`${base}/businesses`} class="inline-block bg-purple text-cream font-display font-bold px-6 py-3 rounded-md hover:bg-purple/90 transition-colors">
            View Full Business Directory
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
