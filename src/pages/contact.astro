---
import BaseLayout from '../layouts/BaseLayout.astro';
import MarketIcon from '../components/MarketIcon.astro';
import siteConfig from '../data/site-config.json';

const base = import.meta.env.BASE_URL;
const email = siteConfig.contact.email;

// Build a mailto: link with URL-encoded subject + body so each topic opens
// the visitor's mail client pre-filled with a template they can edit.
function mailto(subject: string, body: string) {
  const params = new URLSearchParams({ subject, body });
  // URLSearchParams encodes spaces as `+`; mailto: clients prefer `%20`.
  return `mailto:${email}?${params.toString().replace(/\+/g, '%20')}`;
}

// Each topic = one card. The mailto template gives visitors a runway so the
// market gets the info it needs without people staring at a blank email.
const topics = [
  {
    icon: 'heart',
    label: 'General Inquiry',
    blurb: "Just saying hi, asking a question, or something else.",
    href: mailto(
      'Hello from kinderhookfarmersmarket.com',
      `Hi Kinderhook Farmers Market team,\n\n`
    ),
    cta: 'Email us',
  },
  {
    icon: 'apple',
    label: 'Become a Vendor',
    blurb: "Local farmers, bakers, makers, and food producers who want to sell at the market.",
    href: mailto(
      'Vendor Application — [your business name]',
      [
        `Hi,`,
        ``,
        `I'd love to be a vendor at the market. Here's a bit about us:`,
        ``,
        `• Business name:`,
        `• What we sell:`,
        `• Website / Instagram:`,
        `• Where we're located:`,
        `• Saturdays we're available:`,
        `• Why we'd like to join:`,
        ``,
        `Thanks!`,
      ].join('\n')
    ),
    cta: 'Apply by email',
  },
  {
    icon: 'ok',
    label: 'Sponsor the Market',
    blurb: "Local businesses that want to invest in keeping the Saturday market going.",
    href: mailto(
      'Sponsorship inquiry',
      [
        `Hi,`,
        ``,
        `Our business is interested in sponsoring the market. A quick intro:`,
        ``,
        `• Business name:`,
        `• Website:`,
        `• What we'd like to sponsor (full season, a particular day, music, signage…):`,
        `• Best way to reach us:`,
        ``,
        `Thanks!`,
      ].join('\n')
    ),
    cta: 'Sponsor the market',
  },
  {
    icon: 'sunflower',
    label: 'Volunteer',
    blurb: "Set-up, breakdown, info table, kids' activities — every Saturday needs hands.",
    href: mailto(
      'Volunteer at the market',
      [
        `Hi,`,
        ``,
        `I'd love to volunteer with the market this season. A bit about me:`,
        ``,
        `• Name:`,
        `• Saturdays I'm available:`,
        `• What I'd like to help with:`,
        ``,
        `Thanks!`,
      ].join('\n')
    ),
    cta: 'Volunteer by email',
  },
  {
    icon: 'star',
    label: 'Submit an Event',
    blurb: "Running a gallery opening, library talk, or community event in Kinderhook? We'll cross-promote on the calendar.",
    href: mailto(
      'Event for the calendar — [event name]',
      [
        `Hi,`,
        ``,
        `We're running an event in Kinderhook and would love it on the market calendar:`,
        ``,
        `• Event name:`,
        `• Date / time:`,
        `• Location:`,
        `• Host:`,
        `• Link / RSVP:`,
        `• Brief description (one or two sentences):`,
        ``,
        `Thanks!`,
      ].join('\n')
    ),
    cta: 'Submit by email',
  },
  {
    icon: 'music',
    label: 'Play the Market',
    blurb: "Local musicians who want to perform during the 10 AM–noon slot on a Saturday.",
    href: mailto(
      'Performer interest — [your act]',
      [
        `Hi,`,
        ``,
        `I'd love to play the market this season. A quick intro:`,
        ``,
        `• Act name:`,
        `• Style / genre:`,
        `• Listen here (Spotify, Bandcamp, YouTube, etc.):`,
        `• Saturdays I'm available:`,
        `• Anything else we should know:`,
        ``,
        `Thanks!`,
      ].join('\n')
    ),
    cta: 'Pitch by email',
  },
  {
    icon: 'history',
    label: 'Press & Media',
    blurb: "Reporters, bloggers, photographers, podcasters working on a Hudson Valley piece.",
    href: mailto(
      'Press inquiry',
      [
        `Hi,`,
        ``,
        `I'm working on a story about the market. A bit about the angle:`,
        ``,
        `• Outlet:`,
        `• Story angle:`,
        `• Deadline:`,
        ``,
        `Thanks!`,
      ].join('\n')
    ),
    cta: 'Email press contact',
  },
];
---

<BaseLayout
  title="Contact Us"
  description="Get in touch with the Kinderhook Farmers Market. Vendor applications, performer pitches, sponsorships, volunteering, event submissions, press inquiries — pick a topic and email us at khookfarmersmarket@icloud.com."
  canonicalPath="/contact"
>
  <!-- Hero -->
  <section class="bg-cream py-12 md:py-16">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h1 class="font-display font-bold text-4xl md:text-5xl text-black mb-4">Get in Touch</h1>
      <p class="text-black text-lg leading-relaxed mb-6">
        We read every email. Pick the topic that fits and your mail app will open with a head start — fill it in and hit send.
      </p>
      <p class="font-display font-bold text-xl">
        <a
          href={`mailto:${email}`}
          class="text-orange hover:text-purple transition-colors"
        >
          {email}
        </a>
      </p>
    </div>
  </section>

  <!-- Topic cards -->
  <section class="bg-cream pb-12">
    <div class="max-w-3xl mx-auto px-4">
      <ul class="space-y-4">
        {topics.map((t) => (
          <li>
            <a
              href={t.href}
              class="block bg-black hover:bg-purple transition-colors rounded-xl p-5 md:p-6 text-cream"
            >
              <div class="flex items-start gap-4">
                <span
                  class="block w-10 h-10 md:w-12 md:h-12 shrink-0 mt-1"
                  style={`background-color: var(--color-cream); -webkit-mask-image: url('${base}/icons/FM-${t.icon.toUpperCase()}-ICON.png'); mask-image: url('${base}/icons/FM-${t.icon.toUpperCase()}-ICON.png'); -webkit-mask-size: contain; mask-size: contain; -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-position: center; mask-position: center;`}
                  aria-hidden="true"
                ></span>
                <div class="flex-1">
                  <h2 class="font-display font-bold text-xl md:text-2xl mb-1">{t.label}</h2>
                  <p class="text-cream/80 text-sm md:text-base mb-3 leading-relaxed">{t.blurb}</p>
                  <p class="font-display font-bold text-orange">
                    {t.cta} <span aria-hidden="true">→</span>
                  </p>
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Follow -->
  <section class="bg-cream pb-16">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="font-logo uppercase tracking-[0.08em] text-sm text-black/70 mb-5">Follow along</h2>
      <div class="flex justify-center items-center gap-6">
        <a
          href={siteConfig.contact.facebook}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Follow on Facebook"
          class="inline-flex items-center justify-center hover:opacity-80 transition-opacity"
        >
          <span
            class="block w-12 h-12"
            style={`background-color: #2E1F2F; -webkit-mask-image: url('${base}/icons/FM-FACEBOOK-ICON.png'); mask-image: url('${base}/icons/FM-FACEBOOK-ICON.png'); -webkit-mask-size: contain; mask-size: contain; -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-position: center; mask-position: center;`}
          ></span>
        </a>
        <a
          href={siteConfig.contact.instagram}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Follow on Instagram"
          class="inline-flex items-center justify-center hover:opacity-80 transition-opacity"
        >
          <span
            class="block w-12 h-12"
            style={`background-color: #2E1F2F; -webkit-mask-image: url('${base}/icons/FM-INSTAGRAM-ICON.png'); mask-image: url('${base}/icons/FM-INSTAGRAM-ICON.png'); -webkit-mask-size: contain; mask-size: contain; -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-position: center; mask-position: center;`}
          ></span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
