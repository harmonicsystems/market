---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StructuredData from '../../components/StructuredData.astro';
import MarketIcon from '../../components/MarketIcon.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const allBusinesses = await getCollection('businesses');

// Group by type
const typeLabels: Record<string, string> = {
  'real-estate': 'Real Estate',
  'professional-services': 'Professional Services',
  'cultural': 'Arts & Culture',
  'financial': 'Financial Services',
  'legal': 'Legal',
  'nonprofit': 'Nonprofits & Community',
  'farm': 'Farms & Agriculture',
  'religious': 'Houses of Worship',
  'restaurant': 'Dining',
  'retail': 'Shops & Retail',
  'government': 'Government',
};

// Sort businesses alphabetically
const sortedBusinesses = allBusinesses.sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<BaseLayout
  title="Kinderhook Business Directory"
  description="Explore local businesses in Kinderhook, NY — members of the Kinderhook Business and Professional Association (KBPA). Shops, restaurants, farms, services, and community organizations in Columbia County's Hudson Valley."
  canonicalPath="/businesses"
>
  <StructuredData slot="head" type="breadcrumb" data={{ items: [{ name: 'Home', url: '/' }, { name: 'Business Directory', url: '/businesses' }] }} />

  <section class="bg-cream py-12">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h1 class="font-display font-bold text-4xl md:text-5xl text-black mb-4">
          Kinderhook Business Directory
        </h1>
        <p class="text-black/90 text-lg max-w-2xl mx-auto">
          Discover the businesses, organizations, and community partners that make Kinderhook a vibrant village in the Hudson Valley. All members of the <strong>Kinderhook Business and Professional Association</strong>.
        </p>
      </div>

      <!-- Business Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedBusinesses.map((biz) => (
          <article class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition-shadow">
            <a href={`${base}/businesses/${biz.data.slug}`} class="block">
              <div class="h-32 bg-gradient-to-br from-teal/15 to-lime/15 flex items-center justify-center">
                <span class="opacity-40"><MarketIcon name="ok" class="w-16 h-16" /></span>
              </div>
            </a>
            <div class="p-5">
              <div class="flex items-start justify-between gap-2 mb-2">
                <h2 class="font-display font-bold text-lg text-black leading-tight">
                  <a href={`${base}/businesses/${biz.data.slug}`} class="hover:text-orange transition-colors">
                    {biz.data.name}
                  </a>
                </h2>
              </div>
              <span class="inline-block bg-teal/10 text-teal text-xs font-medium px-2 py-1 rounded-md mb-3">
                {typeLabels[biz.data.type] || biz.data.type}
              </span>
              <p class="text-black/70 text-sm">{biz.data.description}</p>
              {biz.data.website && (
                <a
                  href={biz.data.website}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1 text-teal text-sm font-semibold mt-3 hover:underline"
                >
                  Visit Website
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              )}
            </div>
          </article>
        ))}
      </div>

      <!-- KBPA Info -->
      <div class="mt-16 bg-white rounded-xl p-8 text-center shadow-md">
        <h2 class="font-display font-bold text-2xl text-black mb-4">
          About the KBPA
        </h2>
        <p class="text-black/70 mb-4 max-w-2xl mx-auto">
          The <strong>Kinderhook Business and Professional Association</strong> works to support local businesses, promote economic development, and enhance the quality of life in Kinderhook. The KBPA sponsors the Kinderhook Farmers Market and other community events throughout the year.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={`${base}/about`} class="inline-block bg-orange text-white font-display font-bold px-6 py-3 rounded-md hover:bg-orange/90 transition-colors">
            Learn More
          </a>
          <a href={`${base}/contact`} class="inline-block bg-teal text-white font-display font-bold px-6 py-3 rounded-md hover:bg-teal/90 transition-colors">
            Join the KBPA
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
